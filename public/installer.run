#!/usr/bin/env bash
# GWI POS Installer -- installer.run (Orchestrator)
#
# Provisions Ubuntu 22.04+ NUCs as POS stations.
#
# Roles:
#   Server   -- POS app + web UI + heartbeat + sync agent + backups + SSH + TeamViewer (no kiosk)
#   Backup   -- Hot standby: PG streaming replication + keepalived VIP failover
#   Terminal -- Chromium kiosk pointing at server + SSH
#
# Usage:
#   curl -fsSL https://ordercontrolcenter.com/installer.run -o installer.run && chmod +x installer.run && sudo ./installer.run
#
# Resume after failure:
#   sudo ./installer.run --resume-from=schema
#   sudo ./installer.run --resume-from=services
#
# Dry run (no changes):
#   sudo ./installer.run --dry-run
#
# Re-running is idempotent: detects existing registration, backs up data,
# pulls latest code, restarts services.

# ── AUTHORITY MODEL ──────────────────────────────────────────────────
# MC/Neon = sole authority for schema version, provisioning state, rollout
# NUC/local PG = authority for runtime operations during outage
# Installer = prepares local env + PG, but NEVER declares schema truth
# _venue_schema_state is MC-owned -- installer must NOT write to it
# ─────────────────────────────────────────────────────────────────────

set -euo pipefail

# Non-interactive mode for all apt operations (prevents dpkg dialog hangs)
export DEBIAN_FRONTEND=noninteractive
export DEBCONF_NONINTERACTIVE_SEEN=true

# ─────────────────────────────────────────────────────────────────────────────
# Installer Version (stamped at build time by build-installer-bundle.sh)
# ─────────────────────────────────────────────────────────────────────────────
INSTALLER_VERSION="2.0.11"
INSTALLER_VERSION="2.0.11"
INSTALLER_BUILD_DATE="2026-04-04T23:04:02Z"
INSTALLER_GIT_SHA="__INSTALLER_GIT_SHA__"

# ─────────────────────────────────────────────────────────────────────────────
# SELF-UPDATE -- ALWAYS download latest installer before doing ANYTHING
# Never run stale code. Every install, every update, every --resume-from.
# Skip only if --skip-self-update is passed (for the re-exec after update).
# ─────────────────────────────────────────────────────────────────────────────
# Installer is built + bundled in the POS Vercel deployment (vercel-build.js).
# DO NOT serve from MC -- MC has an unbundled copy without embedded modules.
_SELF_UPDATE_URL="https://ordercontrolcenter.com/installer.run"
_SKIP_SELF_UPDATE=false
for _arg in "$@"; do
  [[ "$_arg" == "--skip-self-update" ]] && _SKIP_SELF_UPDATE=true
done

if [[ "$_SKIP_SELF_UPDATE" == "false" ]] && [[ "${GWI_OFFLINE_INSTALL:-}" != "1" ]]; then
  echo -e "\033[0;36m[GWI POS]\033[0m Checking for latest installer..."
  _TEMP_INSTALLER=$(mktemp /tmp/installer-update.XXXXXX)
  if curl -fsSL --connect-timeout 10 --max-time 30 "$_SELF_UPDATE_URL" -o "$_TEMP_INSTALLER" 2>/dev/null; then
    _REMOTE_SHA=$(grep '^INSTALLER_GIT_SHA=' "$_TEMP_INSTALLER" 2>/dev/null | head -1 | cut -d'"' -f2)
    _REMOTE_VER=$(grep '^INSTALLER_VERSION=' "$_TEMP_INSTALLER" 2>/dev/null | head -1 | cut -d'"' -f2)
    # Update if SHA OR version differs -- catches both code changes and version bumps
    if [[ -n "$_REMOTE_SHA" ]] && { [[ "$_REMOTE_SHA" != "$INSTALLER_GIT_SHA" ]] || [[ "$_REMOTE_VER" != "$INSTALLER_VERSION" ]]; }; then
      echo -e "\033[0;32m[GWI POS]\033[0m Updating installer: v${INSTALLER_VERSION}/${INSTALLER_GIT_SHA} → v${_REMOTE_VER}/${_REMOTE_SHA}"
      # Keep last-known-good copy for rollback
      cp "$0" "${0}.bak"
      # Replace ourselves with the new version
      cp "$_TEMP_INSTALLER" "$0"
      chmod +x "$0"
      rm -f "$_TEMP_INSTALLER"
      # Clear old extracted modules so new ones get extracted from updated payload
      rm -rf "$(cd "$(dirname "$0")" && pwd)/installer-modules"
      # Re-exec with same args + --skip-self-update to prevent infinite loop
      exec "$0" "$@" --skip-self-update
    else
      echo -e "\033[0;32m[GWI POS]\033[0m Installer is up to date (v${INSTALLER_VERSION}, ${INSTALLER_GIT_SHA})"
    fi
    rm -f "$_TEMP_INSTALLER"
  else
    echo -e "\033[1;33m[WARNING]\033[0m Could not reach update server -- running local version ($INSTALLER_GIT_SHA)"
    rm -f "$_TEMP_INSTALLER"
  fi
fi

# ── Concurrent install lock ──
INSTALL_LOCKFILE="/tmp/gwi-installer.lock"
exec 9>"$INSTALL_LOCKFILE"
if ! flock -n 9; then
  echo -e "\033[0;31m[ERROR]\033[0m Another installer instance is already running (lock: $INSTALL_LOCKFILE)" >&2
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────────────────────

APP_BASE="/opt/gwi-pos"
APP_DIR="$APP_BASE/app"
INSTALL_START=$(date +%s)
# Health tracker -- accumulates non-fatal warnings for honest summary
INSTALL_WARNINGS=()
track_warn() { INSTALL_WARNINGS+=("$1"); warn "$1"; }
# Section timing -- logs elapsed time per deploy step
SECTION_START=0
start_timer() { SECTION_START=$(date +%s); }
end_timer() {
  local elapsed=$(( $(date +%s) - SECTION_START ))
  log "$1 completed in ${elapsed}s"
}

# ── Signal handlers -- clean exit on Ctrl+C or SIGTERM ──
_installer_cleanup() {
  local exit_code=$?
  _stop_spinner 2>/dev/null || true
  if [[ $exit_code -ne 0 ]]; then
    echo ""
    err "Installer interrupted (signal/exit code: $exit_code)"
    err "Resume with: sudo ./installer.run --resume-from=<stage>"
  fi
  exit $exit_code
}
trap _installer_cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

ENV_FILE="$APP_BASE/.env"
KEY_DIR="$APP_BASE/keys"
BACKUP_DIR="$APP_BASE/backups"
BACKUP_SCRIPT="$APP_BASE/backup-pos.sh"
MC_URL="${MISSION_CONTROL_URL:-https://app.thepasspos.com}"
MC_REGISTER_URL="$MC_URL/api/fleet/register"
BACKOFFICE_API_URL="${BACKOFFICE_API_URL_OVERRIDE:-https://api.ordercontrolcenter.com}"
# Repo URL set during registration (encryptedRepoUrl), fallback for backwards compat
GIT_REPO="${GIT_REPO_OVERRIDE:-}"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log()    { echo -e "${GREEN}[GWI POS]${NC} $*"; }
warn()   { echo -e "${YELLOW}[WARNING]${NC} $*"; }
err()    { echo -e "${RED}[ERROR]${NC} $*" >&2; }
header() { echo -e "\n${CYAN}═══════════════════════════════════════════════════════${NC}"; echo -e "${CYAN}  $*${NC}"; echo -e "${CYAN}═══════════════════════════════════════════════════════${NC}\n"; }

# Progress spinner for long-running commands
# Usage: run_with_progress "message" command arg1 arg2 ...
_SPINNER_PID=""
_start_spinner() {
  local msg="$1"
  log "$msg"
  if [[ -t 1 ]]; then
    # Interactive terminal -- animated spinner
    (
      local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
      local i=0 elapsed=0
      while true; do
        printf "\r${GREEN}[GWI POS]${NC} %s %s [%ds]  " "$msg" "${chars:i%10:1}" "$elapsed"
        sleep 1
        elapsed=$((elapsed + 1))
        i=$((i + 1))
      done
    ) &
    _SPINNER_PID=$!
  else
    # Non-interactive -- just print a dot every 30s
    (
      while true; do sleep 30; printf "."; done
    ) &
    _SPINNER_PID=$!
  fi
  # Spinner cleanup handled by _stop_spinner and main EXIT trap
  # Do NOT set a trap here -- it overwrites the main cleanup chain
}
_stop_spinner() {
  if [[ -n "$_SPINNER_PID" ]] && kill -0 "$_SPINNER_PID" 2>/dev/null; then
    kill "$_SPINNER_PID" 2>/dev/null
    wait "$_SPINNER_PID" 2>/dev/null
    _SPINNER_PID=""
    [[ -t 1 ]] && printf "\r\033[K"  # clear spinner line only on TTY
  fi
}
run_with_progress() {
  local msg="$1"
  shift
  _start_spinner "$msg"
  local exit_code=0
  "$@" || exit_code=$?
  _stop_spinner
  return $exit_code
}

# ─────────────────────────────────────────────────────────────────────────────
# Install progress reporting to Mission Control
# ─────────────────────────────────────────────────────────────────────────────

_report_install_progress() {
  local stage="$1"
  local status="$2"  # STARTING, COMPLETED, FAILED, SKIPPED
  local error_code="${3:-}"
  local output="${4:-}"

  # Only report if we have MC connectivity + server identity
  [[ -z "$SERVER_NODE_ID" ]] && return 0
  [[ -z "$SERVER_API_KEY" ]] && return 0

  local mc_url="${MC_URL:-https://app.thepasspos.com}"
  local payload
  payload=$(jq -nc \
    --arg stage "$stage" \
    --arg status "$status" \
    --arg errorCode "$error_code" \
    --arg output "${output:0:500}" \
    --arg installerVersion "$INSTALLER_VERSION" \
    --arg role "$STATION_ROLE" \
    '{stage: $stage, status: $status, errorCode: $errorCode, output: $output, installerVersion: $installerVersion, role: $role}' \
  ) 2>/dev/null || return 0

  # Compute HMAC signature for fleet auth
  local sig
  sig=$(printf '%s' "$payload" | openssl dgst -sha256 -hmac "$SERVER_API_KEY" 2>/dev/null | awk '{print $NF}') \
    || { [[ -z "${_HMAC_WARNED:-}" ]] && warn "Progress reporting disabled (openssl HMAC failed)" && _HMAC_WARNED=1; return 0; }

  # Fire and forget -- don't block install for reporting
  curl -sf -X POST "${mc_url}/api/fleet/install-progress" \
    -H "Content-Type: application/json" \
    -H "X-Server-Node-Id: $SERVER_NODE_ID" \
    -H "Authorization: Bearer $SERVER_API_KEY" \
    -H "X-Hardware-Fingerprint: ${HARDWARE_FINGERPRINT:-none}" \
    -H "X-Request-Signature: $sig" \
    -d "$payload" \
    --connect-timeout 5 --max-time 10 >/dev/null 2>&1 &
}

# ─────────────────────────────────────────────────────────────────────────────
# Shared state variables (set by modules, consumed by later modules)
# ─────────────────────────────────────────────────────────────────────────────
POSUSER=""
POSUSER_HOME=""
STATION_ROLE=""
ALREADY_REGISTERED=false
REG_CODE=""
SERVER_URL=""
PRIMARY_NUC_IP=""
VIRTUAL_IP=""
PREV_ROLE=""
SERVER_NODE_ID=""
SERVER_API_KEY=""
HARDWARE_FINGERPRINT=""
DATABASE_URL=""
DIRECT_URL=""
DEPLOY_TOKEN=""
USE_LOCAL_PG=false
NEON_DATABASE_URL=""
NEON_DIRECT_URL=""
SYNC_ENABLED="false"
LOCATION_ID=""
MC_LOCATION_ID=""
CLOUD_ORGANIZATION_ID=""
CLOUD_ENTERPRISE_ID=""
VENUE_SLUG=""
DB_USER=""
DB_NAME=""
DB_PASSWORD=""
REPL_PASSWORD=""
NEON_PSQL="psql"
CHROMIUM_BIN=""
POS_READY=false
VENUE_NAME=""
LOCATION_NAME=""
FREE_MB=""

# ─────────────────────────────────────────────────────────────────────────────
# Source all modules
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MODULES_DIR="$SCRIPT_DIR/installer-modules"
POS_BASE_URL="${POS_BASE_URL:-https://ordercontrolcenter.com}"

# ALWAYS extract fresh modules from embedded payload -- never use stale modules on disk
rm -rf "$MODULES_DIR"
if grep -q '^__MODULES_PAYLOAD__$' "$0"; then
  log "Extracting embedded modules..."
  sed '1,/^__MODULES_PAYLOAD__$/d' "$0" | base64 -d | tar xz -C "$SCRIPT_DIR"
  if [[ ! -f "$MODULES_DIR/01-preflight.sh" ]]; then
    err "Module extraction failed"
    exit 1
  fi
  log "Extracted $(ls "$MODULES_DIR"/*.sh | wc -l) modules"
else
  err "No embedded payload in installer.run"
  err "Download the full installer: curl -fsSL https://ordercontrolcenter.com/installer.run"
  exit 1
fi

for mod in "$MODULES_DIR"/*.sh; do
  if [[ -f "$mod" ]]; then
    source "$mod"
  fi
done

# ─────────────────────────────────────────────────────────────────────────────
# Parse --resume-from argument
# ─────────────────────────────────────────────────────────────────────────────

RESUME_FROM=""
DRY_RUN=false
INSTALLER_ARGS=()
for arg in "$@"; do
  if [[ "$arg" =~ ^--resume-from=(.+)$ ]]; then
    RESUME_FROM="${BASH_REMATCH[1]}"
  elif [[ "$arg" == "--dry-run" ]]; then
    DRY_RUN=true
  elif [[ "$arg" == "--skip-self-update" ]]; then
    : # Already handled above, ignore here
  else
    INSTALLER_ARGS+=("$arg")
  fi
done
export DRY_RUN

# ─────────────────────────────────────────────────────────────────────────────
# Detect first boot vs re-install (available to all stages via IS_REINSTALL)
# ─────────────────────────────────────────────────────────────────────────────
if [[ -f /opt/gwi-pos/.first-boot-done ]]; then
  IS_REINSTALL=true
  log "Detected existing installation -- running as RE-INSTALL"
else
  IS_REINSTALL=false
  log "No existing installation detected -- running as FRESH INSTALL"
fi
export IS_REINSTALL

# ─────────────────────────────────────────────────────────────────────────────
# Stage execution with checkpoints
# ─────────────────────────────────────────────────────────────────────────────

header "GWI POS Installer"

# Display version info
if [[ "$INSTALLER_VERSION" != "__INSTALLER_VERSION__" ]] && [[ -n "$INSTALLER_VERSION" ]]; then
  log "Installer v${INSTALLER_VERSION} (built ${INSTALLER_BUILD_DATE:-unknown}, sha ${INSTALLER_GIT_SHA:-unknown})"
  log "  POS assets: ${POS_BASE_URL}"
  log "  MC API:     ${MC_URL}"
  log "  Self-update: ${_SELF_UPDATE_URL}"
else
  log "Installer version: development (unstamped)"
fi

# ── Persistent install log ──
INSTALL_LOG="/opt/gwi-pos/logs/install-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "$(dirname "$INSTALL_LOG")" 2>/dev/null || true
exec > >(tee -a "$INSTALL_LOG") 2>&1
log "Install log: $INSTALL_LOG"

if [[ "$DRY_RUN" == "true" ]]; then
  echo ""
  echo -e "${YELLOW}═══════════════════════════════════════════════════════${NC}"
  echo -e "${YELLOW}  DRY RUN MODE -- no changes will be made${NC}"
  echo -e "${YELLOW}═══════════════════════════════════════════════════════${NC}"
  echo ""
fi

# When resuming, load saved state from .env (needed for modules that depend on
# earlier modules having set variables like POSUSER, STATION_ROLE, etc.)
if [[ -n "$RESUME_FROM" ]]; then
  log "Resume mode: will skip stages before '$RESUME_FROM'"

  # Restore critical variables from .env and system state
  if [[ -f "$ENV_FILE" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      line="${line#"${line%%[![:space:]]*}"}"
      [[ -z "$line" ]] && continue
      key="${line%%=*}"; val="${line#*=}"
      # Strip surrounding quotes (single or double)
      val="${val#\"}"
      val="${val%\"}"
      val="${val#\'}"
      val="${val%\'}"
      case "$key" in
        STATION_ROLE)         STATION_ROLE="$val" ;;
        SERVER_NODE_ID)       SERVER_NODE_ID="$val" ;;
        SERVER_API_KEY)       SERVER_API_KEY="$val" ;;
        HARDWARE_FINGERPRINT) HARDWARE_FINGERPRINT="$val" ;;
        DATABASE_URL)         DATABASE_URL="$val" ;;
        DIRECT_URL)           DIRECT_URL="$val" ;;
        SERVER_URL)           SERVER_URL="$val" ;;
        PRIMARY_NUC_IP)       PRIMARY_NUC_IP="$val" ;;
        VIRTUAL_IP)           VIRTUAL_IP="$val" ;;
        LOCATION_ID)          LOCATION_ID="$val" ;;
        CLOUD_LOCATION_ID)    MC_LOCATION_ID="$val" ;;
        CLOUD_ORGANIZATION_ID) CLOUD_ORGANIZATION_ID="$val" ;;
        CLOUD_ENTERPRISE_ID)  CLOUD_ENTERPRISE_ID="$val" ;;
        NEON_DATABASE_URL)    NEON_DATABASE_URL="$val" ;;
        NEON_DIRECT_URL)      NEON_DIRECT_URL="$val" ;;
        SYNC_ENABLED)         SYNC_ENABLED="$val" ;;
        DB_USER)              DB_USER="$val" ;;
        DB_NAME)              DB_NAME="$val" ;;
        DB_PASSWORD)          DB_PASSWORD="$val" ;;
        REPL_PASSWORD)        REPL_PASSWORD="$val" ;;
        POS_VENUE_SLUG)       VENUE_SLUG="$val" ;;
        BACKOFFICE_API_URL)   BACKOFFICE_API_URL="$val" ;;
      esac
    done < "$ENV_FILE"
  fi

  # Resolve POSUSER from flag, SUDO_USER, or UID 1000
  if [[ -z "$POSUSER" ]]; then
    _prev_arg=""
    for arg in "${INSTALLER_ARGS[@]}"; do
      if [[ "$_prev_arg" == "--user" ]]; then POSUSER="$arg"; break; fi
      _prev_arg="$arg"
    done
  fi
  if [[ -z "$POSUSER" ]]; then POSUSER="${SUDO_USER:-}"; fi
  if [[ -z "$POSUSER" ]] || [[ "$POSUSER" == "root" ]]; then
    POSUSER=$(getent passwd 1000 | cut -d: -f1 || echo "")
    if [[ -z "$POSUSER" ]]; then
      POSUSER=$(awk -F: '$3>=1000 && $3<65534 && $7 !~ /nologin|false/ {print $1; exit}' /etc/passwd || echo "")
    fi
  fi
  if [[ -n "$POSUSER" ]]; then
    POSUSER_HOME=$(getent passwd "$POSUSER" | cut -d: -f6)
  fi

  ALREADY_REGISTERED=true
  USE_LOCAL_PG=true
  if [[ -z "$GIT_REPO" ]]; then
    GIT_REPO="https://github.com/GetwithitMan/gwi-pos.git"
  fi

  # Set NEON_PSQL
  NEON_PSQL="/usr/lib/postgresql/17/bin/psql"
  if [[ ! -x "$NEON_PSQL" ]]; then
    NEON_PSQL="psql"
  fi

  log "Restored state: STATION_ROLE=$STATION_ROLE, POSUSER=$POSUSER"
fi

# ── Soft dependency checks (warn-only, never block install) ──
command -v jq >/dev/null 2>&1 || track_warn "jq not found -- install progress reporting will be degraded"
command -v python3 >/dev/null 2>&1 || track_warn "python3 not found -- version checking will be degraded"

# ── Stage completion markers (crash recovery) ──────────────────────────────
# After each stage succeeds, a versioned marker is written.
# On re-run (resume), completed stages are skipped.
# Markers include installer version to prevent skipping stages that
# changed meaning between installer versions.
STAGE_STATE_DIR="$APP_BASE/shared/state"

_stage_marker() {
    echo "$STAGE_STATE_DIR/.stage-${1}-done"
}

_stage_done() {
    local marker
    marker="$(_stage_marker "$1")"
    # Accept markers from ANY version (the old versioned format or the new plain format)
    [[ -f "$marker" ]] || ls "$STAGE_STATE_DIR"/.stage-${1}-done-v* &>/dev/null 2>&1
}

_mark_stage_done() {
    mkdir -p "$STAGE_STATE_DIR"
    date -u +%FT%TZ > "$(_stage_marker "$1")"
}

_reset_all_markers() {
    mkdir -p "$STAGE_STATE_DIR"
    rm -f "$STAGE_STATE_DIR"/.stage-*-done* 2>/dev/null || true
    log "Stage markers reset for fresh install"
}

run_stage() {
    local num="$1"
    local name="$2"
    local func="$3"
    shift 3
    # Any remaining args are passed to the stage function

    if _stage_done "$num"; then
        log "Stage $num ($name) already complete -- skipping"
        _report_install_progress "$name" "SKIPPED"
        return 0
    fi

    header "Stage $num: $name"
    _report_install_progress "$name" "STARTING"
    start_timer

    # Tee stderr to a temp file for error capture while preserving console output
    local _stage_err_file
    _stage_err_file=$(mktemp /tmp/gwi-stage-err-XXXXXX 2>/dev/null || echo "")
    if "$func" "$@" 2> >(tee "$_stage_err_file" >&2); then
        rm -f "$_stage_err_file"
        _mark_stage_done "$num"
        _report_install_progress "$name" "COMPLETED"
        end_timer "Stage $num ($name)"
    else
        local _stage_err
        _stage_err=$(tail -c 500 "$_stage_err_file" 2>/dev/null || echo "")
        rm -f "$_stage_err_file"
        _report_install_progress "$name" "FAILED" "ERR-INST-${num}" "$_stage_err"
        err "Stage $num ($name) FAILED"
        err "Fix the issue and re-run: sudo ./installer.run"
        err "  (completed stages will be skipped automatically)"
        return 1
    fi

    # Record legacy checkpoint
    mkdir -p "$APP_BASE"
    echo "$name" > "$APP_BASE/.install-checkpoint"
}

# Define stages in order
STAGES=(preflight register secrets database deploy_app schema services ha remote_access finalize system_hardening dashboard)

CHECKPOINT_FILE="$APP_BASE/.install-checkpoint"

# ── Stage number map ─────────────────────────────────────────────────────────
declare -A STAGE_NUM
STAGE_NUM=(
  [preflight]="01"
  [register]="02"
  [secrets]="03"
  [database]="04"
  [deploy_app]="05"
  [schema]="06"
  [services]="07"
  [ha]="08"
  [remote_access]="09"
  [finalize]="10"
  [system_hardening]="11"
  [dashboard]="12"
)

declare -A STAGE_LABEL
STAGE_LABEL=(
  [preflight]="Preflight Checks"
  [register]="Registration"
  [secrets]="Secrets & Keys"
  [database]="Database"
  [deploy_app]="Deploy App"
  [schema]="Schema"
  [services]="Services"
  [ha]="HA Failover"
  [remote_access]="Remote Access"
  [finalize]="Finalize"
  [system_hardening]="System Hardening"
  [dashboard]="Dashboard"
)

# ── Marker reset logic ───────────────────────────────────────────────────────
# Fresh install (no --resume-from): reset all markers so every stage runs.
# --resume-from: keep markers, but clear markers for the target stage and all
# stages after it so they re-run from the requested point.
if [[ -n "$RESUME_FROM" ]]; then
  # Validate --resume-from value
  _valid_resume=false
  _clearing=false
  for _s in "${STAGES[@]}"; do
    if [[ "$_s" == "$RESUME_FROM" ]]; then
      _valid_resume=true
      _clearing=true
    fi
    if [[ "$_clearing" == "true" ]]; then
      # Remove marker for this stage (keyed by number) so run_stage will re-run it
      rm -f "$(_stage_marker "${STAGE_NUM[$_s]}")" 2>/dev/null || true
    fi
  done
  if [[ "$_valid_resume" != "true" ]]; then
    err "Invalid --resume-from value: '$RESUME_FROM'"
    err "Valid stages: ${STAGES[*]}"
    exit 1
  fi
  log "Resume mode: markers cleared from '$RESUME_FROM' onward"
else
  # Fresh install -- reset all markers
  _reset_all_markers
fi

# ── Two-phase install with mid-reboot ────────────────────────────────────────
# Phase 1 (stages 01-10): Core POS — registration, database, deploy, schema,
#   services, HA, remote access, finalize. Reboots to activate SDDM auto-login
#   and systemd services cleanly.
# Phase 2 (stages 11-12): System hardening + dashboard. Runs automatically
#   on first boot after Phase 1 via a systemd oneshot service.
#
# --resume-from skips this logic and runs exactly what was requested.

PHASE1_STAGES=(preflight register secrets database deploy_app schema services ha remote_access finalize)
PHASE2_STAGES=(system_hardening dashboard)
PHASE2_TOKEN="$APP_BASE/shared/state/.phase2-pending"
PHASE2_SERVICE="/etc/systemd/system/gwi-installer-phase2.service"

# Check if this is Phase 2 resuming after reboot
if [[ -f "$PHASE2_TOKEN" ]] && [[ -z "$RESUME_FROM" ]]; then
  log "Phase 2: Resuming after reboot (hardening + dashboard)..."
  for stage in "${PHASE2_STAGES[@]}"; do
    _num="${STAGE_NUM[$stage]}"
    _label="${STAGE_LABEL[$stage]}"
    run_stage "$_num" "$_label" "run_${stage}" || exit 1
  done
  # Phase 2 complete -- clean up token and oneshot service
  rm -f "$PHASE2_TOKEN"
  rm -f "$PHASE2_SERVICE"
  rm -f "$APP_BASE/installer-phase2.run"
  systemctl disable gwi-installer-phase2.service 2>/dev/null || true
  systemctl daemon-reload 2>/dev/null || true

  # ── Final install verification ──
  log ""
  log "Verifying full installation..."
  _install_ok=true
  _checks=()

  # Check POS service
  if systemctl is-active thepasspos >/dev/null 2>&1; then
    _checks+=("POS service: active")
  else
    _checks+=("POS service: NOT ACTIVE")
    _install_ok=false
  fi

  # Check dashboard
  if command -v gwi-dashboard >/dev/null 2>&1; then
    _checks+=("Dashboard: installed")
  else
    _checks+=("Dashboard: NOT INSTALLED")
    _install_ok=false
  fi

  # Check health
  if curl -sf --connect-timeout 3 --max-time 5 http://localhost:3005/api/health/ready >/dev/null 2>&1; then
    _checks+=("Health: ready")
  else
    _checks+=("Health: not ready (may still be starting)")
  fi

  # Check SDDM auto-login
  if grep -q "Session=plasma.desktop" /etc/sddm.conf 2>/dev/null; then
    _checks+=("Auto-login: configured")
  else
    _checks+=("Auto-login: NOT configured")
  fi

  log "Installation verification:"
  for _c in "${_checks[@]}"; do
    log "  $_c"
  done

  if [[ "$_install_ok" == "true" ]]; then
    log ""
    log "INSTALLATION COMPLETE -- all checks passed."
    _report_install_progress "summary" "COMPLETED" "" "phase=2,warnings=${#INSTALL_WARNINGS[@]}"
  else
    log ""
    track_warn "Installation has issues -- see verification above"
    _report_install_progress "summary" "DEGRADED" "" "phase=2,warnings=${#INSTALL_WARNINGS[@]}"
  fi

  # Write final install marker
  echo "COMPLETE $(date -u +%FT%TZ)" > "$APP_BASE/shared/state/.install-complete"

  log ""

  # Flush log
  if [[ -n "${INSTALL_LOG:-}" ]]; then
    exec 1>&- 2>&-
    sleep 1
    exec 1>/dev/tty 2>&1 || true
    sync
  fi
  exit 0
fi

# ── Execute Phase 1 stages ───────────────────────────────────────────────────
# Both fresh installs and re-installs use the two-phase flow.
# --resume-from still respects stage markers (completed stages are skipped).
for stage in "${PHASE1_STAGES[@]}"; do
  _num="${STAGE_NUM[$stage]}"
  _label="${STAGE_LABEL[$stage]}"
  if [[ "$stage" == "preflight" ]]; then
    run_stage "$_num" "$_label" run_preflight "${INSTALLER_ARGS[@]}" || exit 1
  else
    run_stage "$_num" "$_label" "run_${stage}" || exit 1
  fi
done

# ── Post-Phase-1: health check + reboot ─────────────────────────────────────
if [[ "$DRY_RUN" == "true" ]]; then
  echo ""
  echo -e "${YELLOW}═══════════════════════════════════════════════════════${NC}"
  echo -e "${YELLOW}  DRY RUN COMPLETE -- no changes were made${NC}"
  echo -e "${YELLOW}═══════════════════════════════════════════════════════${NC}"
  echo ""
else
  # Quick health check -- confirm POS is responding before reboot
  if [[ "$STATION_ROLE" == "server" ]] || [[ "$STATION_ROLE" == "backup" ]]; then
    log "Running post-install health check..."
    _health_ok=false
    _consecutive=0
    for _attempt in 1 2 3 4 5; do
      if curl -sf --connect-timeout 3 --max-time 5 http://localhost:3005/api/health/ready >/dev/null 2>&1; then
        _consecutive=$((_consecutive + 1))
        if [[ $_consecutive -ge 2 ]]; then
          _health_ok=true
          break
        fi
      else
        _consecutive=0
      fi
      sleep 3
    done
    if [[ "$_health_ok" == "true" ]]; then
      log "Health check passed -- POS is responding on port 3005"
    else
      track_warn "Health check FAILED -- POS not responding on port 3005 after 3 attempts"
      warn "Proceeding to reboot anyway -- services should recover on boot"
      _report_install_progress "health_check" "FAILED" "" "POS not responding on port 3005 after 3 attempts"
    fi
  fi

  _report_install_progress "phase1" "COMPLETED" "" "warnings=${#INSTALL_WARNINGS[@]}"

  log ""
  log "Phase 1 complete! Core POS installed."
  log "  Setting up Phase 2 (hardening + dashboard) to run after reboot..."
  log ""

  # ── Create Phase 2 token + oneshot service ──
  # Phase 2 runs on first boot: system hardening + dashboard install.
  # Uses a systemd oneshot that calls the installer with the phase2 token.
  mkdir -p "$(dirname "$PHASE2_TOKEN")"
  date -u +%FT%TZ > "$PHASE2_TOKEN"

  # Copy installer to a stable location (the ~/installer.run may get deleted)
  cp "$0" "$APP_BASE/installer-phase2.run" 2>/dev/null || true
  chmod +x "$APP_BASE/installer-phase2.run" 2>/dev/null || true

  cat > "$PHASE2_SERVICE" << 'P2SVCEOF'
[Unit]
Description=GWI POS Installer Phase 2 (hardening + dashboard)
After=network-online.target local-fs.target thepasspos.service
Wants=network-online.target
RequiresMountsFor=/opt/gwi-pos

[Service]
Type=oneshot
ExecStartPre=/usr/bin/test -f /opt/gwi-pos/shared/state/.phase2-pending
ExecStart=/opt/gwi-pos/installer-phase2.run --skip-self-update
RemainAfterExit=no
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
P2SVCEOF

  systemctl daemon-reload
  systemctl enable gwi-installer-phase2.service
  log "Phase 2 service enabled -- will run automatically after reboot"

  # Flush install log
  if [[ -n "${INSTALL_LOG:-}" ]]; then
    exec 1>&- 2>&-
    sleep 1
    exec 1>/dev/tty 2>&1 || true
    sync
    echo "[GWI POS] Phase 1 log finalized: $INSTALL_LOG"
  fi

  echo "[GWI POS] Rebooting now -- Phase 2 will run automatically..."
  sync
  reboot
fi










































# End of installer — payload below
exit 0
__MODULES_PAYLOAD__

