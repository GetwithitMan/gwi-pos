#!/usr/bin/env bash
# =============================================================================
# GWI POS — Hardening Report to Mission Control
# =============================================================================
# Installed by Ansible mc_phone_home role.
# Reads hardening-status.json + inventory.json, constructs an HMAC-signed
# payload, and POSTs to MC /api/fleet/heartbeat with healthDetails.
# On failure: queues to report-queue/ for offline retry.
# On success: flushes any queued reports (oldest first).
#
# Reuses HMAC-SHA256 signing pattern from heartbeat.sh.
# =============================================================================
# Managed by GWI POS Ansible — do not edit manually

STATE_DIR="{{ gwi_state_dir }}"
ENV_FILE="{{ gwi_env_file }}"
APP_DIR="{{ gwi_app_dir }}"
QUEUE_DIR="{{ gwi_state_dir }}/report-queue"
EVENTS_LOG="{{ gwi_state_dir }}/install-events.jsonl"

{% raw %}
# ── Load environment ─────────────────────────────────────────────────────────
NODE_ID=""
API_KEY=""
MC_URL=""
TELEMETRY_ENABLED="true"

if [ -f "$ENV_FILE" ]; then
  NODE_ID=$(grep '^SERVER_NODE_ID=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")
  API_KEY=$(grep '^SERVER_API_KEY=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")
  MC_URL=$(grep '^MISSION_CONTROL_URL=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")

  TEL=$(grep '^gwi_telemetry_enabled=' "$ENV_FILE" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")
  if [ "$TEL" = "false" ]; then
    TELEMETRY_ENABLED="false"
  fi
fi

# Bail early if identity is incomplete — cannot report without credentials
if [ -z "$NODE_ID" ] || [ -z "$API_KEY" ] || [ -z "$MC_URL" ]; then
  logger -t gwi-pos-report "Skipping hardening report — missing NODE_ID, API_KEY, or MC_URL"
  exit 0
fi

# ── Read baseline version ────────────────────────────────────────────────────
BASELINE_VERSION="unknown"
if [ -f "$APP_DIR/installer/VERSION" ]; then
  BASELINE_VERSION=$(cat "$APP_DIR/installer/VERSION" 2>/dev/null | tr -d '[:space:]')
fi

# ── Read hardening status ────────────────────────────────────────────────────
HARDENING_STATUS="{}"
if [ -f "${STATE_DIR}/hardening-status.json" ]; then
  HARDENING_STATUS=$(cat "${STATE_DIR}/hardening-status.json" 2>/dev/null || echo "{}")
  # Validate JSON
  if ! echo "$HARDENING_STATUS" | python3 -m json.tool >/dev/null 2>&1; then
    HARDENING_STATUS="{}"
  fi
fi

# ── Read inventory (respects telemetry opt-out) ──────────────────────────────
INVENTORY_STATUS="{}"
if [ "$TELEMETRY_ENABLED" = "true" ] && [ -f "${STATE_DIR}/inventory.json" ]; then
  INVENTORY_STATUS=$(cat "${STATE_DIR}/inventory.json" 2>/dev/null || echo "{}")
  if ! echo "$INVENTORY_STATUS" | python3 -m json.tool >/dev/null 2>&1; then
    INVENTORY_STATUS="{}"
  fi
fi

# ── Read drift scan if available ─────────────────────────────────────────────
DRIFT_STATUS="{}"
if [ -f "${STATE_DIR}/drift-scan.json" ]; then
  DRIFT_STATUS=$(cat "${STATE_DIR}/drift-scan.json" 2>/dev/null || echo "{}")
  if ! echo "$DRIFT_STATUS" | python3 -m json.tool >/dev/null 2>&1; then
    DRIFT_STATUS="{}"
  fi
fi

# ── Construct payload ────────────────────────────────────────────────────────
GENERATED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

BODY=$(cat <<EOJSON
{
  "nodeId": "${NODE_ID}",
  "baselineVersion": "${BASELINE_VERSION}",
  "healthDetails": {
    "schema_version": "1.0",
    "producer": "report-hardening",
    "generated_at": "${GENERATED_AT}",
    "node_id": "${NODE_ID}",
    "baseline_version": "${BASELINE_VERSION}",
    "telemetry_enabled": ${TELEMETRY_ENABLED},
    "hardening_status": ${HARDENING_STATUS},
    "inventory": ${INVENTORY_STATUS},
    "drift": ${DRIFT_STATUS}
  }
}
EOJSON
)

# ── HMAC-SHA256 signature (matches heartbeat.sh pattern) ─────────────────────
SIG=$(echo -n "$BODY" | openssl dgst -sha256 -hmac "$API_KEY" | awk '{print $NF}')

# ── Helper: send a payload to MC ─────────────────────────────────────────────
send_to_mc() {
  local payload="$1"
  local sig
  sig=$(echo -n "$payload" | openssl dgst -sha256 -hmac "$API_KEY" | awk '{print $NF}')

  HTTP_CODE=$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 \
    -X POST "${MC_URL}/api/fleet/heartbeat" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${API_KEY}" \
    -H "X-Server-Node-Id: ${NODE_ID}" \
    -H "X-Request-Signature: ${sig}" \
    -d "$payload" 2>/dev/null || echo "000")

  echo "$HTTP_CODE"
}

# ── Helper: queue a failed report ─────────────────────────────────────────────
queue_report() {
  local payload="$1"
  local report_type="${2:-hardening_report}"
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  # next_retry_at: 60 seconds from now
  local next_retry
  next_retry=$(date -u -d "+60 seconds" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
    || date -u -v+60S +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
    || echo "$now")

  mkdir -p "$QUEUE_DIR"

  local queue_file="${QUEUE_DIR}/report-$(date +%Y%m%d-%H%M%S)-$$.json"

  cat > "$queue_file" <<EOQUEUE
{
  "schema_version": "1.0",
  "report_type": "${report_type}",
  "created_at": "${now}",
  "retry_count": 0,
  "next_retry_at": "${next_retry}",
  "payload": ${payload}
}
EOQUEUE

  logger -t gwi-pos-report "Report queued for retry: ${queue_file}"
}

# ── Helper: prune queue to retention limits ───────────────────────────────────
prune_queue() {
  local max_files=50
  local max_bytes=$((10 * 1024 * 1024))
  local max_age_days=7
  local pruned=0

  if [ ! -d "$QUEUE_DIR" ] || [ -z "$(ls -A "$QUEUE_DIR" 2>/dev/null)" ]; then
    return
  fi

  # Prune files older than 7 days
  while IFS= read -r -d '' old_file; do
    rm -f "$old_file"
    pruned=$((pruned + 1))
  done < <(find "$QUEUE_DIR" -name '*.json' -type f -mtime +"$max_age_days" -print0 2>/dev/null)

  # Prune to max file count
  local file_count
  file_count=$(find "$QUEUE_DIR" -name '*.json' -type f 2>/dev/null | wc -l)
  if [ "$file_count" -gt "$max_files" ]; then
    local excess=$((file_count - max_files))
    find "$QUEUE_DIR" -name '*.json' -type f -printf '%T+ %p\n' 2>/dev/null \
      | sort | head -n "$excess" | awk '{print $2}' \
      | while read -r f; do rm -f "$f"; pruned=$((pruned + 1)); done
  fi

  # Prune to max size
  local total_size
  total_size=$(du -sb "$QUEUE_DIR" 2>/dev/null | awk '{print $1}')
  while [ "${total_size:-0}" -gt "$max_bytes" ]; do
    local oldest
    oldest=$(find "$QUEUE_DIR" -name '*.json' -type f -printf '%T+ %p\n' 2>/dev/null \
      | sort | head -1 | awk '{print $2}')
    if [ -z "$oldest" ]; then
      break
    fi
    rm -f "$oldest"
    pruned=$((pruned + 1))
    total_size=$(du -sb "$QUEUE_DIR" 2>/dev/null | awk '{print $1}')
  done

  if [ "$pruned" -gt 0 ]; then
    local prune_ts
    prune_ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    echo "{\"event\":\"queue_pruned\",\"timestamp\":\"$prune_ts\",\"count\":$pruned,\"reason\":\"limit_exceeded\",\"producer\":\"report-hardening\"}" \
      >> "$EVENTS_LOG"
    logger -t gwi-pos-report "Pruned ${pruned} queued report(s) — retention limit exceeded"
  fi
}

# ── Helper: flush queued reports (oldest first) ──────────────────────────────
flush_queue() {
  if [ ! -d "$QUEUE_DIR" ] || [ -z "$(ls -A "$QUEUE_DIR" 2>/dev/null)" ]; then
    return
  fi

  # Process oldest first
  find "$QUEUE_DIR" -name '*.json' -type f -printf '%T+ %p\n' 2>/dev/null \
    | sort | awk '{print $2}' \
    | while read -r queue_file; do
      if [ ! -f "$queue_file" ]; then
        continue
      fi

      # Extract the payload from the queued file
      local queued_payload
      queued_payload=$(python3 -c "
import json, sys
try:
    data = json.load(open('$queue_file'))
    print(json.dumps(data.get('payload', {})))
except:
    print('{}')
" 2>/dev/null || echo "{}")

      if [ "$queued_payload" = "{}" ]; then
        # Corrupt queue file — remove it
        rm -f "$queue_file"
        continue
      fi

      local flush_code
      flush_code=$(send_to_mc "$queued_payload")

      if [ "$flush_code" -ge 200 ] && [ "$flush_code" -lt 300 ] 2>/dev/null; then
        rm -f "$queue_file"
        logger -t gwi-pos-report "Flushed queued report: $(basename "$queue_file")"
      else
        # Update retry_count and next_retry_at with exponential backoff
        local retry_count
        retry_count=$(python3 -c "
import json
try:
    data = json.load(open('$queue_file'))
    print(data.get('retry_count', 0))
except:
    print('0')
" 2>/dev/null || echo "0")

        local new_count=$((retry_count + 1))
        # Exponential backoff: 60s, 120s, 240s, 480s, ... max 3600s (1h)
        local backoff=$((60 * (2 ** retry_count)))
        if [ "$backoff" -gt 3600 ]; then
          backoff=3600
        fi

        local next_retry
        next_retry=$(date -u -d "+${backoff} seconds" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
          || date -u -v+"${backoff}"S +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
          || date -u +"%Y-%m-%dT%H:%M:%SZ")

        python3 -c "
import json
try:
    data = json.load(open('$queue_file'))
    data['retry_count'] = $new_count
    data['next_retry_at'] = '$next_retry'
    with open('$queue_file', 'w') as f:
        json.dump(data, f, indent=2)
except:
    pass
" 2>/dev/null || true

        # Stop trying to flush — MC is likely still down
        logger -t gwi-pos-report "Queue flush failed at $(basename "$queue_file") — will retry in ${backoff}s"
        break
      fi
    done
}

# ── Main: send report to MC ─────────────────────────────────────────────────
RESPONSE_CODE=$(send_to_mc "$BODY")

if [ "$RESPONSE_CODE" -ge 200 ] && [ "$RESPONSE_CODE" -lt 300 ] 2>/dev/null; then
  logger -t gwi-pos-report "Hardening report sent successfully (HTTP ${RESPONSE_CODE})"

  # Success — try flushing any queued reports
  flush_queue
else
  logger -t gwi-pos-report "Hardening report failed (HTTP ${RESPONSE_CODE}) — queueing for retry"

  # Queue the failed report
  queue_report "$BODY" "hardening_report"
fi

# Always prune queue at the end
prune_queue

exit 0
{% endraw %}
