#include <tunables/global>

profile gwi-pos /usr/bin/node {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>
  #include <abstractions/ssl_certs>

  # Node.js binary
  /usr/bin/node rix,
  /usr/local/bin/node rix,

  # Application directory — read + execute
  /opt/gwi-pos/** r,
  /opt/gwi-pos/current/** r,
  /opt/gwi-pos/current/node_modules/.bin/* rix,
  /opt/gwi-pos/releases/** r,

  # Writable paths
  /opt/gwi-pos/shared/ rw,
  /opt/gwi-pos/shared/** rw,
  /opt/gwi-pos/shared/logs/** w,
  /opt/gwi-pos/shared/state/** rw,
  /opt/gwi-pos/shared/data/** rw,
  /tmp/** rw,
  /var/tmp/** rw,

  # .env read
  /opt/gwi-pos/.env r,
  /opt/gwi-pos/current/.env r,
  /opt/gwi-pos/current/.env.local r,

  # Prisma engine binaries
  /opt/gwi-pos/current/node_modules/.prisma/** rmix,
  /opt/gwi-pos/current/src/generated/** r,

  # PostgreSQL socket (local DB)
  /var/run/postgresql/ r,
  /var/run/postgresql/** rw,

  # Network access (TCP for PG, HTTP for sync, WebSocket)
  network inet stream,
  network inet dgram,
  network inet6 stream,
  network inet6 dgram,
  network unix stream,
  network unix dgram,

  # System info (health checks, hardware detection)
  /proc/ r,
  /proc/sys/kernel/random/uuid r,
  /proc/sys/kernel/random/boot_id r,
  /proc/meminfo r,
  /proc/cpuinfo r,
  /proc/uptime r,
  /proc/loadavg r,
  /proc/self/** r,
  /sys/class/net/** r,
  /sys/devices/** r,

  # Serial port access (printers, scales)
  /dev/ttyUSB* rw,
  /dev/ttyACM* rw,
  /dev/usb/** rw,

  # Deny everything else by default (implicit in AppArmor)

  # Explicitly deny sensitive paths
  deny /etc/shadow r,
  deny /etc/gshadow r,
  deny /root/** rwx,
  deny /home/*/.ssh/** rwx,
  deny /opt/gwi-pos/keys/private.pem r,  # private key only needed at install time
  deny /opt/gwi-pos/.backup-key r,        # backup key only needed by cron
}
