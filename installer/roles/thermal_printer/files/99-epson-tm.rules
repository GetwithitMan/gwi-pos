# =============================================================================
# GWI POS — Epson Thermal Printer udev Rules
# =============================================================================
# Managed by Ansible — do not edit manually
#
# Grants appropriate permissions for supported Epson TM-series printers
# so the POS application can communicate directly via USB.
# =============================================================================

# Epson TM-T20III
SUBSYSTEM=="usb", ATTR{idVendor}=="04b8", ATTR{idProduct}=="0e28", MODE="0666", GROUP="lpadmin"

# Epson TM-T88VI
SUBSYSTEM=="usb", ATTR{idVendor}=="04b8", ATTR{idProduct}=="0e15", MODE="0666", GROUP="lpadmin"

# Epson TM-T88V
SUBSYSTEM=="usb", ATTR{idVendor}=="04b8", ATTR{idProduct}=="0e11", MODE="0666", GROUP="lpadmin"

# Epson TM-m30III
SUBSYSTEM=="usb", ATTR{idVendor}=="04b8", ATTR{idProduct}=="0e36", MODE="0666", GROUP="lpadmin"
