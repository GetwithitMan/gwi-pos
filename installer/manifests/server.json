{
  "schema_version": "1.0",
  "producer": "gwi-pos-baseline",
  "role": "server",
  "description": "Primary POS server — runs gwi-pos and gwi-agent Docker containers, manages peripherals.",
  "services": {
    "required": [
      {
        "name": "gwi-pos",
        "type": "docker",
        "tier": "critical",
        "description": "POS application server (Docker container)",
        "health_check": "docker inspect --format='{{.State.Health.Status}}' gwi-pos 2>/dev/null || echo 'unhealthy'"
      },
      {
        "name": "gwi-agent",
        "type": "docker",
        "tier": "degraded",
        "description": "Sync agent for MC deploy commands and upstream replication (Docker container)",
        "health_check": "docker inspect --format='{{.State.Status}}' gwi-agent 2>/dev/null || echo 'not running'"
      }
    ],
    "optional": [
      {
        "name": "keepalived",
        "tier": "degraded",
        "description": "HA virtual IP failover (only if HA configured)",
        "condition": "gwi_virtual_ip is defined and gwi_virtual_ip != ''"
      }
    ]
  },
  "ports": {
    "required": [
      { "port": 22, "protocol": "tcp", "description": "SSH remote access" },
      { "port": 3005, "protocol": "tcp", "description": "POS application" }
    ],
    "optional": [
      { "port": 5432, "protocol": "tcp", "description": "PostgreSQL (if local PG)" }
    ]
  },
  "peripherals": {
    "optional": [
      {
        "type": "printer",
        "description": "Epson thermal receipt printer",
        "vendor_ids": ["04b8"],
        "supported_models": ["TM-T20III", "TM-T88V", "TM-T88VI", "TM-m30III"]
      },
      {
        "type": "touchscreen",
        "description": "Any libinput-compatible touchscreen; eGalax/eGTouch preferred",
        "vendor_ids": ["0eef"]
      },
      {
        "type": "card_reader",
        "description": "ID Tech VP3300/VP3350 payment terminal",
        "vendor_ids": ["0acd"]
      },
      {
        "type": "scale",
        "description": "CAS PDN scale via FTDI or Prolific adapter",
        "vendor_ids": ["0403", "067b"]
      }
    ]
  }
}
