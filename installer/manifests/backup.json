{
  "schema_version": "1.0",
  "producer": "gwi-pos-baseline",
  "role": "backup",
  "description": "Hot standby NUC — PostgreSQL streaming replica with keepalived VIP failover.",
  "services": {
    "required": [
      {
        "name": "postgresql",
        "tier": "critical",
        "description": "PostgreSQL streaming replica"
      },
      {
        "name": "keepalived",
        "tier": "critical",
        "description": "HA virtual IP failover"
      }
    ],
    "optional": [
      {
        "name": "gwi-pos",
        "type": "docker",
        "tier": "degraded",
        "description": "POS application (standby — started on failover promotion)",
        "health_check": "docker inspect --format='{{.State.Health.Status}}' gwi-pos 2>/dev/null || echo 'unhealthy'"
      },
      {
        "name": "gwi-agent",
        "type": "docker",
        "tier": "degraded",
        "description": "Sync agent (standby — started on failover promotion)",
        "health_check": "docker inspect --format='{{.State.Status}}' gwi-agent 2>/dev/null || echo 'not running'"
      }
    ]
  },
  "ports": {
    "required": [
      { "port": 22, "protocol": "tcp", "description": "SSH remote access" },
      { "port": 5432, "protocol": "tcp", "description": "PostgreSQL replication" }
    ],
    "optional": [
      { "port": 3005, "protocol": "tcp", "description": "POS application (after promotion)" }
    ]
  },
  "peripherals": {
    "optional": []
  }
}
