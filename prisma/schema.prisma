// ============================================
// ORGANIZATION & LOCATIONS (Skill 53)
// ============================================

// NOTE: If you add a new model that intentionally omits `deletedAt`, also add
// it to NO_SOFT_DELETE_MODELS in src/lib/db.ts or soft-delete filtering will break.

model Organization {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  locations Location[]
}

model Location {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name     String
  slug     String? @unique // URL-friendly identifier for venue subdomains
  address  String?
  phone    String?
  timezone String  @default("America/New_York")
  isActive Boolean @default(true)

  // Settings
  settings Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  // Cloud identity — populated from Mission Control during registration/heartbeat
  cloudLocationId     String? // CloudLocation.id in Mission Control
  cloudOrganizationId String? // CloudOrganization.id in Mission Control
  cloudEnterpriseId   String? // CloudEnterprise.id (null if org not in enterprise)

  // Relations
  employees             Employee[]
  roles                 Role[]
  categories            Category[]
  menuItems             MenuItem[]
  modifierGroups        ModifierGroup[]
  orderTypes            OrderType[]
  orders                Order[]
  tables                Table[]
  sections              Section[]
  drawers               Drawer[]
  shifts                Shift[]
  timeClock             TimeClockEntry[]
  discountRules         DiscountRule[]
  prepStations          PrepStation[]
  customers             Customer[]
  giftCards             GiftCard[]
  houseAccounts         HouseAccount[]
  coupons               Coupon[]
  reservations          Reservation[]
  entertainmentWaitlist      EntertainmentWaitlist[]
  floorPlanElements          FloorPlanElement[]
  entertainmentSessions      EntertainmentSession[]
  entertainmentSessionEvents EntertainmentSessionEvent[]
  entertainmentResources     EntertainmentResource[]
  // Seat-Level Ticketing
  seats                 Seat[]
  events                Event[]
  tickets               Ticket[]

  // Liquor Builder (Skill: Liquor)
  spiritCategories   SpiritCategory[]
  bottleProducts     BottleProduct[]
  spiritUpsellEvents SpiritUpsellEvent[]

  // Tip Sharing
  tipOutRules TipOutRule[]
  tipShares   TipShare[]
  tipPools    TipPool[]

  // Tip Bank Ledger (Skill 250)
  tipLedgers       TipLedger[]
  tipLedgerEntries TipLedgerEntry[]
  tipTransactions  TipTransaction[]

  // Tip Groups (Skill 252)
  tipGroupTemplates     TipGroupTemplate[]
  tipGroups             TipGroup[]
  tipGroupMemberships   TipGroupMembership[]
  tipGroupSegments      TipGroupSegment[]
  orderOwnerships       OrderOwnership[]
  orderOwnershipEntries OrderOwnershipEntry[]

  // Tip Adjustments & Compliance (Skills 256, 259)
  tipAdjustments      TipAdjustment[]
  cashTipDeclarations CashTipDeclaration[]

  // Tip Debt (Skill 278 - Chargeback Remainder)
  tipDebts TipDebt[]

  // Order Details (multi-tenancy)
  orderItems         OrderItem[]
  orderItemModifiers OrderItemModifier[]
  orderDiscounts     OrderDiscount[]
  payments           Payment[]

  // Menu Details (multi-tenancy)
  modifiers Modifier[]

  // Combos (multi-tenancy)
  comboTemplates           ComboTemplate[]
  comboComponents          ComboComponent[]
  comboComponentOptions    ComboComponentOption[]
  orderItemComboSelections OrderItemComboSelection[]

  // Multi-role support (multi-tenancy)
  employeeRoles EmployeeRole[]

  // Operations (multi-tenancy)
  paidInOuts          PaidInOut[]
  sectionAssignments  SectionAssignment[]
  voidLogs            VoidLog[]
  refundLogs          RefundLog[]
  breaks              Break[]
  remoteVoidApprovals RemoteVoidApproval[]

  // Transactions (multi-tenancy)
  couponRedemptions        CouponRedemption[]
  giftCardTransactions     GiftCardTransaction[]
  houseAccountTransactions HouseAccountTransaction[]

  // Events (multi-tenancy)
  eventPricingTiers     EventPricingTier[]
  eventTableConfigs     EventTableConfig[]
  // Inventory & Tax (multi-tenancy)
  taxRules              TaxRule[]
  inventoryTransactions InventoryTransaction[]
  stockAlerts           StockAlert[]

  // Inventory & Recipe Costing (Skill 115)
  voidReasons               VoidReason[]
  compReasons               CompReason[]
  reasonAccess              ReasonAccess[]
  storageLocations          StorageLocation[]
  inventoryItems            InventoryItem[]
  inventoryItemStorages     InventoryItemStorage[]
  prepItems                 PrepItem[]
  prepItemIngredients       PrepItemIngredient[]
  menuItemRecipes           MenuItemRecipe[]
  menuItemRecipeIngredients MenuItemRecipeIngredient[]
  modifierInventoryLinks    ModifierInventoryLink[]
  inventoryCounts           InventoryCount[]
  inventoryCountItems       InventoryCountItem[]
  inventoryItemTransactions InventoryItemTransaction[]
  vendors                   Vendor[]
  invoices                  Invoice[]
  invoiceLineItems          InvoiceLineItem[]
  wasteLogEntries           WasteLogEntry[]
  inventorySettings         InventorySettings?

  // Liquor Builder (multi-tenancy)
  recipeIngredients    RecipeIngredient[]
  spiritModifierGroups SpiritModifierGroup[]

  // Menu Item Ingredients (multi-tenancy)
  ingredientCategories IngredientCategory[]
  ingredientSwapGroups IngredientSwapGroup[]
  ingredients          Ingredient[]
  ingredientRecipes    IngredientRecipe[]
  menuItemIngredients  MenuItemIngredient[]
  orderItemIngredients OrderItemIngredient[]

  // Modifier Group Templates (for quick item-specific group creation)
  modifierGroupTemplates ModifierGroupTemplate[]
  modifierTemplates      ModifierTemplate[]

  // Hardware Management
  printers          Printer[]
  kdsScreens        KDSScreen[]
  kdsScreenStations KDSScreenStation[]
  kdsScreenLinks    KDSScreenLink[]
  stations          Station[]
  terminals         Terminal[]
  printRules        PrintRule[]
  printRoutes       PrintRoute[]
  printJobs         PrintJob[]
  paymentReaders    PaymentReader[]
  readerLogs        PaymentReaderLog[]
  scales            Scale[]
  cfdSettings       CfdSettings?

  // Order Cards (multi-card tabs)
  orderCards OrderCard[]

  // Datacap Advanced Features (Sprint 3)
  digitalReceipts DigitalReceipt[]
  chargebackCases ChargebackCase[]
  cardProfiles    CardProfile[]
  walkoutRetries  WalkoutRetry[]

  // Sync Audit
  syncAuditEntries SyncAuditEntry[]

  // Cloud Event Queue (multi-tenancy)
  cloudEventQueues CloudEventQueue[]

  // Pizza Builder
  pizzaConfigs     PizzaConfig[]
  pizzaSizes       PizzaSize[]
  pizzaCrusts      PizzaCrust[]
  pizzaSauces      PizzaSauce[]
  pizzaCheeses     PizzaCheese[]
  pizzaToppings    PizzaTopping[]
  pizzaSpecialties PizzaSpecialty[]
  orderItemPizzas  OrderItemPizza[]

  // Payroll & Scheduling
  payrollPeriods    PayrollPeriod[]
  payStubs          PayStub[]
  schedules         Schedule[]
  scheduledShifts   ScheduledShift[]
  shiftSwapRequests ShiftSwapRequest[]
  payrollSettings   PayrollSettings?

  // Course Configuration
  courseConfigs CourseConfig[]

  // Daily Prep Counting
  prepTrayConfigs            PrepTrayConfig[]
  dailyPrepCounts            DailyPrepCount[]
  dailyPrepCountItems        DailyPrepCountItem[]
  dailyPrepCountTransactions DailyPrepCountTransaction[]
  ingredientStockAdjustments IngredientStockAdjustment[]

  // Bottle Service (Phase 10)
  bottleServiceTiers BottleServiceTier[]

  // Error Reporting (Domain 16)
  errorLogs    ErrorLog[]
  healthChecks HealthCheck[]

  // Fleet Management (Skill 345)
  serverRegistrationTokens ServerRegistrationToken[]

  // Item-level discounts (P2-D01)
  itemDiscounts OrderItemDiscount[]

  // Mobile Device Authentication (P2-E02)
  registeredDevices RegisteredDevice[]
  mobileSessions    MobileSession[]

  // Hardware Remote Commands (cloud-to-NUC)
  hardwareCommands HardwareCommand[]

  // C-SCHEMA-1: Added reverse relations
  timedSessions TimedSession[]
  auditLogs     AuditLog[]

  // Pricing Options (per-item size/variant pricing)
  pricingOptionGroups         PricingOptionGroup[]
  pricingOptions              PricingOption[]
  pricingOptionInventoryLinks PricingOptionInventoryLink[]

  // Event-sourced orders
  orderEvents        OrderEvent[]
  orderSnapshots     OrderSnapshot[]
  orderItemSnapshots OrderItemSnapshot[]

  // 7shifts integration
  sevenShiftsDailySalesPushes SevenShiftsDailySalesPush[]

  // COGS / MarginEdge Integration
  ingredientCostHistory IngredientCostHistory[]
  vendorOrders          VendorOrder[]
  vendorOrderLineItems  VendorOrderLineItem[]
  wasteLogs             WasteLog[]
  marginEdgeMappings    MarginEdgeProductMapping[]
  inventoryCountEntries InventoryCountEntry[]
  pendingDeductions     PendingDeduction[]

  // Berg Liquor Controls (Tier 1)
  bergPluMappings    BergPluMapping[]
  bergDevices        BergDevice[]
  bergDispenseEvents BergDispenseEvent[]

  // Barcode scanning
  itemBarcodes ItemBarcode[]

  // Cloud-Primary Architecture (Fulfillment + Bridge + Outage Queue)
  fulfillmentEvents       FulfillmentEvent[]
  bridgeCheckpoints       BridgeCheckpoint[]
  outageQueueEntries      OutageQueueEntry[]
  integrationRetryEntries IntegrationRetryEntry[]

  // Reservation Engine
  reservationBlocks   ReservationBlock[]
  reservationDeposits ReservationDeposit[]

  // Per-employee permission overrides
  employeePermissionOverrides EmployeePermissionOverride[]

  // Loyalty System (Migration 098)
  loyaltyPrograms     LoyaltyProgram[]
  loyaltyTransactions LoyaltyTransaction[]

  // Sync Infrastructure
  syncWatermark SyncWatermark?

  // Unified Split Checks (Migration 118)
  itemShares ItemShare[]

  // Multi-tenancy hardening (5K-merchant audit)
  reservationTables ReservationTable[] @relation("ReservationTableLocation")
  deductionRuns     DeductionRun[]
  loyaltyTiers      LoyaltyTier[]      @relation("LoyaltyTierLocation")

  // Peripheral Snapshot (upstream sync to MC)
  peripheralSnapshots PeripheralSnapshot[]

  @@index([organizationId])
}

// ============================================
// CUSTOMERS (Skill 51)
// ============================================

model Customer {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  // Basic info
  firstName   String
  lastName    String
  displayName String? // Optional nickname
  email       String?
  phone       String?

  // Preferences
  notes         String? // Allergies, preferences, etc.
  allergies     String? // Dedicated field for allergy tracking
  favoriteDrink String? // Customer's preferred drink
  favoriteFood  String? // Customer's preferred food
  tags          Json? // VIP, Regular, etc.

  // Loyalty (Skill 52 foundation + 098 Loyalty System)
  loyaltyPoints     Int             @default(0)
  lifetimePoints    Int             @default(0) // Total ever earned, for tier calculation
  loyaltyEnrolledAt DateTime?
  loyaltyProgramId  String?
  loyaltyProgram    LoyaltyProgram? @relation(fields: [loyaltyProgramId], references: [id])
  loyaltyTierId     String?
  loyaltyTier       LoyaltyTier?    @relation(fields: [loyaltyTierId], references: [id])
  totalSpent        Decimal         @default(0) @db.Decimal(10, 2)
  totalOrders       Int             @default(0)
  averageTicket     Decimal         @default(0) @db.Decimal(10, 2)
  lastVisit         DateTime?

  // Marketing
  marketingOptIn Boolean   @default(false)
  birthday       DateTime?

  // Reservation Engine — no-show tracking
  noShowCount            Int       @default(0)
  isBlacklisted          Boolean   @default(false)
  blacklistOverrideUntil DateTime? @db.Date

  isActive Boolean @default(true)

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt     DateTime?
  syncedAt      DateTime?

  // Relations
  orders        Order[]
  houseAccounts HouseAccount[]
  reservations  Reservation[]
  tickets       Ticket[]

  // C-SCHEMA-1: Added reverse relations
  couponRedemptions CouponRedemption[]

  // C-SCHEMA-1: Reverse relations (batch 2)
  cardProfiles CardProfile[]
  errorLogs    ErrorLog[]    @relation("ErrorLogCustomer")

  // Loyalty system reverse relations
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([locationId, email])
  @@unique([locationId, phone])
  @@index([locationId])
  @@index([lastName, firstName])
  @@index([locationId, isActive, deletedAt])
  @@index([loyaltyProgramId])
  @@index([loyaltyTierId])
}

// ============================================
// EMPLOYEES & ROLES (Skill 05)
// ============================================

model Role {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  name        String // Server, Bartender, Manager, Admin
  permissions Json? // Array of permission strings

  // Tip configuration
  isTipped  Boolean @default(false) // Is this a tipped position?
  tipWeight Decimal @default(1.0) @db.Decimal(10, 4) // Weight for role-weighted tip group splits (e.g., 1.5 for lead bartender)

  // Cash handling configuration
  cashHandlingMode CashHandlingMode @default(drawer)
  trackLaborCost   Boolean          @default(true) // Include hours in labor cost reports

  // UX classification — display/filtering only, never used for auth
  roleType    String @default("FOH") // FOH | BOH | ADMIN
  accessLevel String @default("STAFF") // STAFF | MANAGER | OWNER_ADMIN

  sessionTimeoutMinutes Int? // Idle timeout for this role (minutes). 0 = no timeout. null = use venue default.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  employees     Employee[]
  employeeRoles EmployeeRole[]

  // Tip-out rules (role gives/receives tip-outs)
  tipOutRulesFrom TipOutRule[] @relation("TipOutFrom")
  tipOutRulesTo   TipOutRule[] @relation("TipOutTo")

  // Working-as relations (multi-role support)
  workingTimeClockEntries TimeClockEntry[] @relation("WorkingRole")
  workingShifts           Shift[]          @relation("ShiftWorkingRole")

  // Scheduled shifts for this role
  scheduledShifts ScheduledShift[]

  @@unique([locationId, name])
  @@index([locationId])
}

model Employee {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])

  // Identity
  firstName   String
  lastName    String
  displayName String?
  email       String?
  phone       String?

  // Address (for tax documents like W-2)
  address String?
  city    String?
  state   String?
  zipCode String?

  // Authentication
  pin               String // 4-6 digit PIN (hashed)
  password          String? // Optional password for admin access (hashed)
  requiresPinChange Boolean @default(false) // True when provisioned with default PIN

  // Employment
  hourlyRate Decimal? @db.Decimal(10, 2)
  hireDate   DateTime @default(now())
  isActive   Boolean  @default(true)

  // Tax Information (W-4 data)
  federalFilingStatus          String? // 'single' | 'married' | 'head_of_household'
  federalAllowances            Int     @default(0)
  additionalFederalWithholding Decimal @default(0) @db.Decimal(10, 2)
  stateFilingStatus            String? // State-specific filing status
  stateAllowances              Int     @default(0)
  additionalStateWithholding   Decimal @default(0) @db.Decimal(10, 2)
  isExemptFromFederalTax       Boolean @default(false)
  isExemptFromStateTax         Boolean @default(false)

  // Payment Preferences
  paymentMethod     String? // 'direct_deposit' | 'check' | 'cash'
  bankName          String?
  bankRoutingNumber String?
  bankAccountNumber String? // Should be encrypted in production
  bankAccountType   String? // 'checking' | 'savings'
  bankAccountLast4  String? // Last 4 digits for display

  // Year-to-Date Tracking (reset annually)
  ytdGrossEarnings  Decimal   @default(0) @db.Decimal(10, 2) // Total gross (wages + tips + commission)
  ytdGrossWages     Decimal   @default(0) @db.Decimal(10, 2)
  ytdTips           Decimal   @default(0) @db.Decimal(10, 2)
  ytdCommission     Decimal   @default(0) @db.Decimal(10, 2)
  ytdTaxesWithheld  Decimal   @default(0) @db.Decimal(10, 2) // Total taxes (federal + state + FICA)
  ytdFederalTax     Decimal   @default(0) @db.Decimal(10, 2)
  ytdStateTax       Decimal   @default(0) @db.Decimal(10, 2)
  ytdLocalTax       Decimal   @default(0) @db.Decimal(10, 2)
  ytdSocialSecurity Decimal   @default(0) @db.Decimal(10, 2)
  ytdMedicare       Decimal   @default(0) @db.Decimal(10, 2)
  ytdNetPay         Decimal   @default(0) @db.Decimal(10, 2)
  ytdLastUpdated    DateTime?

  // Settings
  color     String? // For floor plan display
