  maxAttempts Int       @default(5)
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?

  @@index([locationId])
  @@index([nextRetryAt])
  @@index([status])
  @@index([locationId, status])
  @@map("cloud_event_queue")
}

// ============================================
// REFUND LOG (P2-P02 — Refund vs Void)
// Tracks post-settlement refunds back to processor
// ============================================

model RefundLog {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  refundAmount   Decimal @db.Decimal(10, 2)
  originalAmount Decimal @db.Decimal(10, 2)
  refundReason   String
  notes          String?

  // Datacap processor reference
  datacapRecordNo String?
  datacapRefNo    String?

  // Approval chain
  approvedById String?
  approvedBy   Employee? @relation("RefundLogApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // Receipt
  receiptPrinted   Boolean   @default(false)
  receiptPrintedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  @@index([locationId])
  @@index([orderId])
  @@index([paymentId])
  @@index([employeeId])
  @@index([createdAt])
  @@index([locationId, createdAt])
  @@index([locationId, updatedAt])
}

// ============================================
// ITEM-LEVEL DISCOUNTS (P2-D01)
// ============================================

model OrderItemDiscount {
  id             String        @id @default(cuid())
  locationId     String
  location       Location      @relation(fields: [locationId], references: [id])
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId    String
  orderItem      OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  discountRuleId String?
  discountRule   DiscountRule? @relation(fields: [discountRuleId], references: [id])
  amount         Decimal       @db.Decimal(10, 2)
  percent        Decimal?      @db.Decimal(8, 4) // Whole-number percentages (0-100), must fit 100.0000
  appliedById    String?
  appliedBy      Employee?     @relation("ItemDiscountAppliedBy", fields: [appliedById], references: [id])
  reason         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?

  @@index([locationId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([locationId, createdAt])
  @@index([orderId, orderItemId])
}

// ============================================
// MOBILE DEVICE AUTHENTICATION (P2-E02)
// Session-based auth for bartender/server phones
// ============================================

model RegisteredDevice {
  id                String          @id @default(cuid())
  locationId        String
  location          Location        @relation(fields: [locationId], references: [id])
  name              String // "Sarah's iPhone"
  deviceType        String          @default("phone") // phone, tablet
  deviceFingerprint String? // browser fingerprint (optional)
  registeredById    String // employeeId who first registered
  registeredBy      Employee        @relation("RegisteredDeviceEmployee", fields: [registeredById], references: [id])
  isActive          Boolean         @default(true)
  lastSeenAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?
  sessions          MobileSession[]

  @@index([locationId])
  @@index([locationId, isActive])
}

model MobileSession {
  id           String           @id @default(cuid())
  locationId   String
  location     Location         @relation(fields: [locationId], references: [id])
  deviceId     String
  device       RegisteredDevice @relation(fields: [deviceId], references: [id])
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])
  sessionToken String           @unique
  expiresAt    DateTime
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  revokedAt    DateTime?
  deletedAt    DateTime?
  syncedAt     DateTime?

  @@index([locationId])
  @@index([sessionToken])
  @@index([employeeId])
}

// ============================================
// HARDWARE REMOTE COMMANDS
// Cloud-to-NUC command queue for printer/reader operations
// ============================================

model HardwareCommand {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  commandType    String // "PRINTER_PING" | "PRINTER_TEST_PAGE" | "PAYMENT_READER_PING"
  targetDeviceId String // Printer or PaymentReader ID
  payload        Json? // Optional extra parameters
  status         String  @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  resultPayload  Json? // Result from the NUC
  errorMessage   String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime // Auto-cleanup: 60s from creation
  deletedAt   DateTime?
  syncedAt    DateTime?

  @@index([locationId, status])
  @@index([locationId])
}

// ──────────────────────────────────────────────────────────────────────
// Event-Sourced Orders
// ──────────────────────────────────────────────────────────────────────

/// Append-only event log for all order domain events.
/// Both Android devices and the server emit events into this table.
/// serverSequence is assigned by Postgres SEQUENCE (nextval) on receipt.
model OrderEvent {
  id              String    @id @default(cuid())
  eventId         String    @unique /// Global identity (ULID/UUID from device)
  orderId         String
  locationId      String
  location        Location  @relation(fields: [locationId], references: [id])
  deviceId        String /// Originating device ID
  deviceCounter   Int /// Monotonic counter per device
  serverSequence  Int       @unique /// Canonical ordering — assigned by nextval('order_event_server_seq')
  type            String /// "ORDER_CREATED", "ITEM_ADDED", etc.
  payloadJson     Json /// Typed event payload
  schemaVersion   Int       @default(1) /// For payload evolution
  correlationId   String? /// Metadata grouping (must not affect reducer)
  deviceCreatedAt DateTime /// Device clock when event was created
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  syncedAt        DateTime?

  @@index([locationId])
  @@index([orderId])
  @@index([orderId, serverSequence])
  @@index([locationId, serverSequence])
  @@index([type])
  @@map("order_events")
}

/// Materialized order state rebuilt from events by the OrderReducer.
/// One row per order — upserted after each event batch is processed.
model OrderSnapshot {
  id                 String              @id /// Same as orderId
  locationId         String
  location           Location            @relation(fields: [locationId], references: [id])
  employeeId         String
  orderType          String              @default("dine_in")
  tableId            String?
  tableName          String?
  tabName            String?
  tabStatus          String?
  guestCount         Int                 @default(1)
  orderNumber        Int                 @default(0)
  displayNumber      String?
  status             String              @default("open")
  notes              String?
  hasPreAuth         Boolean             @default(false)
  cardLast4          String?
  subtotalCents      Int                 @default(0)
  discountTotalCents Int                 @default(0)
  taxTotalCents      Int                 @default(0)
  tipTotalCents      Int                 @default(0)
  totalCents         Int                 @default(0)
  paidAmountCents    Int                 @default(0)
  itemCount          Int                 @default(0)
  hasHeldItems       Boolean             @default(false)
  isClosed           Boolean             @default(false)
  lastEventSequence  Int /// Last serverSequence processed
  items              OrderItemSnapshot[]

  // --- Customer & Attribution ---
  customerId String?
  source     String? /// "online", "kiosk", "pos"

  // --- Split Orders ---
  parentOrderId String?
  splitIndex    Int?

  // --- Order Type ---
  orderTypeId  String?
  customFields Json?

  // --- Seating ---
  baseSeatCount  Int   @default(0)
  extraSeatCount Int   @default(0)
  seatVersion    Int   @default(0)
  seatTimestamps Json?

  // --- Tabs ---
  tabNickname String?

  // --- Dual Pricing ---
  primaryPaymentMethod String? /// 'cash' or 'card'

  // --- Commission ---
  commissionTotal Int @default(0) /// cents

  // --- Reopen ---
  reopenedAt   DateTime?
  reopenedBy   String? /// Employee ID
  reopenReason String?

  // --- Timing ---
  openedAt DateTime? /// When order was opened
  sentAt   DateTime? /// Sent to kitchen

  // --- Pre-Auth (Bar Tabs) ---
  preAuthId        String?
  preAuthAmount    Int? /// cents
  preAuthLast4     String?
  preAuthCardBrand String?
  preAuthExpiresAt DateTime?
  preAuthRecordNo  String?

  // --- Bottle Service ---
  isBottleService           Boolean @default(false)
  bottleServiceCurrentSpend Int? /// cents

  // --- Walkout ---
  isWalkout       Boolean   @default(false)
  walkoutAt       DateTime?
  walkoutMarkedBy String?

  // --- Tab Rollover ---
  rolledOverAt   DateTime?
  rolledOverFrom String?

  // --- Decline Retry ---
  captureDeclinedAt DateTime?
  captureRetryCount Int       @default(0)
  lastCaptureError  String?

  // --- Coursing ---
  currentCourse Int    @default(0)
  courseMode    String @default("off")

  // --- Offline ---
  offlineId         String?
  offlineLocalId    String?
  offlineTimestamp  DateTime?
  offlineTerminalId String?

  // --- Business Day ---
  businessDayDate DateTime?

  // --- Concurrency ---
  version Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  @@index([locationId])
  @@index([locationId, status])
  @@index([locationId, isClosed])
  @@index([locationId, status, createdAt])
  @@index([locationId, openedAt])
  @@index([locationId, tabStatus])
  @@index([locationId, parentOrderId])
  @@index([employeeId])
  @@index([locationId, offlineId])
  @@index([locationId, businessDayDate])
  @@map("order_snapshots")
}

/// Materialized line item state — child of OrderSnapshot.
/// Rebuilt from events alongside the parent snapshot.
model OrderItemSnapshot {
  id                 String        @id /// Same as lineItemId
  snapshotId         String
  snapshot           OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  locationId         String
  location           Location      @relation(fields: [locationId], references: [id])
  menuItemId         String
  name               String
  priceCents         Int
  quantity           Int           @default(1)
  modifiersJson      Json?
  specialNotes       String?
  seatNumber         Int?
  courseNumber       Int?
  isHeld             Boolean       @default(false)
  kitchenStatus      String?
  kitchenSentAt      DateTime?
  soldByWeight       Boolean       @default(false)
  weight             Float?
  weightUnit         String?
  unitPriceCents     Int?
  grossWeight        Float?
  tareWeight         Float?
  status             String?       @default("active")
  isCompleted        Boolean       @default(false)
  resendCount        Int           @default(0)
  delayMinutes       Int?
  totalCents         Int           @default(0)
  pricingOptionId    String?
  pricingOptionLabel String?
  costAtSaleCents    Int?
  pourSize           String?
  pourMultiplier     Float?
  itemDiscountsJson  Json?

  // --- Hold & Fire ---
  holdUntil      DateTime?
  firedAt        DateTime?
  delayStartedAt DateTime?

  // --- KDS ---
  completedAt DateTime?

  // --- Resend ---
  lastResentAt DateTime?
  resendNote   String?

  // --- Entertainment ---
  blockTimeMinutes   Int?
  blockTimeStartedAt DateTime?
  blockTimeExpiresAt DateTime?

  // --- Course ---
  courseStatus String? /// 'pending', 'ready', 'served'

  // --- Waste ---
  wasMade Boolean? /// Made before void?

  // --- Pricing ---
  modifierTotal Int  @default(0) /// cents
  itemTotal     Int  @default(0) /// cents
  cardPrice     Int? /// cents (dual pricing)

  // --- Commission ---
  commissionAmount Int? /// cents

  // --- Tax ---
  isTaxInclusive Boolean @default(false)

  // --- Ownership ---
  addedByEmployeeId String?

  // --- Category ---
  categoryType String?

  // --- Void ---
  voidReason String?

  // --- Idempotency ---
  idempotencyKey String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  @@index([snapshotId])
  @@index([locationId])
  @@index([snapshotId, kitchenStatus])
  @@index([snapshotId, status])
  @@index([locationId, kitchenStatus])
  @@index([menuItemId, createdAt])
  @@map("order_item_snapshots")
}

// ============================================
// QUICK BAR — Per-employee and per-location quick-add presets
// ============================================

model QuickBarPreference {
  id         String    @id @default(cuid())
  locationId String
  employeeId String    @unique
  itemIds    String // JSON array of menuItem IDs
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([locationId])
  @@index([locationId, deletedAt])
}

model QuickBarDefault {
  id         String    @id @default(cuid())
  locationId String    @unique
  itemIds    String // JSON array of menuItem IDs
  deletedAt  DateTime?
  updatedAt  DateTime  @updatedAt
}

// ============================================
// 7SHIFTS INTEGRATION (Skill 7shifts-v1)
// ============================================

// Idempotency table for daily sales receipt pushes to 7shifts
model SevenShiftsDailySalesPush {
  id                   String    @id @default(cuid())
  locationId           String
  location             Location  @relation(fields: [locationId], references: [id])
  businessDate         String // "YYYY-MM-DD" in location timezone
  revenueType          String // "food" | "liquor" | "other" | "combined"
  sevenShiftsReceiptId String? // returned receipt_id from 7shifts
  netTotalCents        Int
  tipsAmountCents      Int       @default(0)
  status               String    @default("pending") // pending|pushed|error
  errorMessage         String?
  pushedAt             DateTime?
  syncedAt             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([locationId, businessDate, revenueType])
  @@index([locationId])
  @@index([businessDate])
  @@index([status])
}

// ============================================
// ORACLE PMS INTEGRATION (Room Charge Idempotency)
// ============================================

enum PmsAttemptStatus {
  PENDING
  COMPLETED
  FAILED
}

model PmsChargeAttempt {
  id                 String           @id @default(cuid())
  idempotencyKey     String           @unique // "{orderId}:{reservationId}:{amountCents}:{chargeCode}"
  locationId         String
  orderId            String
  reservationId      String
  amountCents        Int
  chargeCode         String
  status             PmsAttemptStatus @default(PENDING)
  operaTransactionId String?
  providerRequestId  String? // idempotency key sent to OPERA (if supported)
  employeeId         String? // optional audit trail
  lastErrorMessage   String?
  syncedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([orderId])
  @@index([reservationId])
  @@index([locationId, createdAt])
}

// ============================================
// COGS / MARGIN EDGE / INVOICE EXTENSIONS
// ============================================

// Ingredient cost change audit trail
model IngredientCostHistory {
  id              String    @id @default(cuid())
  locationId      String
  inventoryItemId String
  oldCostPerUnit  Decimal   @db.Decimal(10, 4)
  newCostPerUnit  Decimal   @db.Decimal(10, 4)
  changePercent   Decimal   @db.Decimal(6, 2)
  source          String // 'manual' | 'invoice' | 'marginedge' | 'api'
  invoiceId       String?
  invoiceNumber   String?
  vendorName      String?
  recordedById    String?
  effectiveDate   DateTime
  syncedAt        DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location      Location      @relation(fields: [locationId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([locationId, inventoryItemId, effectiveDate])
  @@index([locationId, effectiveDate])
}

// Purchase orders
model VendorOrder {
  id               String            @id @default(cuid())
  locationId       String
  vendorId         String
  orderNumber      String?
  status           VendorOrderStatus @default(draft)
  orderDate        DateTime          @default(now())
  expectedDelivery DateTime?
  receivedAt       DateTime?
  totalEstimated   Decimal?          @db.Decimal(10, 2)
  totalActual      Decimal?          @db.Decimal(10, 2)
  notes            String?
  createdById      String?
  receivedById     String?
  linkedInvoiceId  String?
  deletedAt        DateTime?
  syncedAt         DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location  Location              @relation(fields: [locationId], references: [id])
  vendor    Vendor                @relation(fields: [vendorId], references: [id])
  lineItems VendorOrderLineItem[]

  @@index([locationId, status])
  @@index([locationId, orderDate])
}

model VendorOrderLineItem {
  id              String    @id @default(cuid())
  locationId      String
  vendorOrderId   String
  inventoryItemId String
  quantity        Decimal   @db.Decimal(10, 4)
  unit            String
  estimatedCost   Decimal?  @db.Decimal(10, 4)
  actualCost      Decimal?  @db.Decimal(10, 4)
  receivedQty     Decimal?  @db.Decimal(10, 4)
  notes           String?
  syncedAt        DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  location      Location      @relation(fields: [locationId], references: [id])
  vendorOrder   VendorOrder   @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([locationId])
  @@index([locationId, vendorOrderId])
  @@index([locationId, deletedAt])
  @@index([vendorOrderId])
  @@index([inventoryItemId])
}

// Individual item counts (COGS-style — simpler than InventoryCountItem)
model InventoryCountEntry {
  id               String    @id @default(cuid())
  locationId       String
  inventoryCountId String
  inventoryItemId  String
  expectedQty      Decimal?  @db.Decimal(10, 4)
  countedQty       Decimal   @db.Decimal(10, 4)
  unit             String
  variance         Decimal?  @db.Decimal(10, 4)
  unitCost         Decimal   @db.Decimal(10, 4)
  varianceCost     Decimal?  @db.Decimal(10, 2)
  notes            String?
  countedById      String?
  syncedAt         DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location       Location       @relation(fields: [locationId], references: [id])
  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  inventoryItem  InventoryItem  @relation(fields: [inventoryItemId], references: [id])

  @@unique([inventoryCountId, inventoryItemId])
  @@index([inventoryCountId])
  @@index([inventoryItemId])
}

// Track waste/spillage/spoilage
model WasteLog {
  id              String      @id @default(cuid())
  locationId      String
  inventoryItemId String?
  bottleProductId String?
  quantity        Decimal     @db.Decimal(10, 4)
  unit            String
  cost            Decimal     @db.Decimal(10, 2)
  reason          WasteReason
  notes           String?
  recordedById    String
  businessDate    DateTime
  syncedAt        DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location      Location       @relation(fields: [locationId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([locationId, businessDate])
  @@index([locationId, reason])
}

// Link MarginEdge products to our InventoryItems
model MarginEdgeProductMapping {
  id                    String    @id @default(cuid())
  locationId            String
  marginEdgeProductId   String
  marginEdgeProductName String
  inventoryItemId       String
  marginEdgeVendorId    String?
  marginEdgeVendorName  String?
  marginEdgeUnit        String?
  lastSyncAt            DateTime?
  isActive              Boolean   @default(true)
  deletedAt             DateTime?
  syncedAt              DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location      Location      @relation(fields: [locationId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([locationId, marginEdgeProductId])
  @@index([locationId, inventoryItemId])
  @@index([locationId, deletedAt])
}

// ============================================
// INVENTORY DEDUCTION OUTBOX
// ============================================

model PendingDeduction {
  id            String          @id @default(cuid())
  locationId    String
  orderId       String          @unique // one deduction job per order
  paymentId     String? // most recent payment that triggered this
  deductionType DeductionType   @default(order_deduction)
  status        DeductionStatus @default(pending)
  attempts      Int             @default(0)
  maxAttempts   Int             @default(5)
  availableAt   DateTime        @default(now()) // for backoff scheduling
  lastError     String?
  lastAttemptAt DateTime?
  succeededAt   DateTime?
  syncedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  location Location       @relation(fields: [locationId], references: [id])
  runs     DeductionRun[]

  @@index([locationId, status, availableAt])
  @@index([status, availableAt]) // for cron processor query
}

model DeductionRun {
  id                 String    @id @default(cuid())
  locationId         String
  location           Location  @relation(fields: [locationId], references: [id])
  pendingDeductionId String
  syncedAt           DateTime?
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  success            Boolean?
  resultSummary      Json? // { liquorDeductions: N, foodDeductions: N, totalCost: X }
  error              String?
  durationMs         Int?
  updatedAt          DateTime  @updatedAt

  pendingDeduction PendingDeduction @relation(fields: [pendingDeductionId], references: [id], onDelete: Cascade)

  @@index([pendingDeductionId])
  @@index([locationId])
}

// ============================================
// BERG LIQUOR CONTROLS — TIER 1 (Sprint 0)
// ============================================

model BergPluMapping {
  id                 String    @id @default(cuid())
  locationId         String
  deviceId           String?
  mappingScopeKey    String // "device:{deviceId}" OR "location:{locationId}" — computed on create
  pluNumber          Int
  bottleProductId    String?
  inventoryItemId    String?
  menuItemId         String?
  description        String?
  pourSizeOzOverride Decimal?  @db.Decimal(6, 3)
  modifierRule       Json?
  trailerRule        Json?
  isActive           Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  location       Location            @relation(fields: [locationId], references: [id])
  device         BergDevice?         @relation(fields: [deviceId], references: [id])
  dispenseEvents BergDispenseEvent[]

  @@unique([mappingScopeKey, pluNumber])
  @@index([locationId])
  @@index([locationId, isActive])
  @@index([locationId, deletedAt])
