  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?
  syncedAt            DateTime?
  entries             TipLedgerEntry[]

  @@unique([locationId, employeeId]) // One ledger per employee per location (was: employeeId @unique globally)
  @@index([employeeId])
  @@index([locationId, updatedAt])
}

model TipLedgerEntry {
  id             String             @id @default(cuid())
  locationId     String
  location       Location           @relation(fields: [locationId], references: [id])
  ledgerId       String
  ledger         TipLedger          @relation(fields: [ledgerId], references: [id])
  employeeId     String
  employee       Employee           @relation(fields: [employeeId], references: [id])
  type           TipLedgerEntryType
  amountCents    Decimal            @db.Decimal(10, 2)
  sourceType     String // DIRECT_TIP, TIP_GROUP, ROLE_TIPOUT, MANUAL_TRANSFER, PAYOUT_CASH, PAYOUT_PAYROLL, CHARGEBACK, ADJUSTMENT
  sourceId       String?
  memo           String?
  adjustmentId   String?
  shiftId        String?
  shift          Shift?             @relation("TipLedgerShift", fields: [shiftId], references: [id])
  orderId        String?
  order          Order?             @relation("TipLedgerOrder", fields: [orderId], references: [id])
  idempotencyKey String?            @unique // Skill 274: dedup guard (e.g. "tip-ledger:{orderId}:{paymentId}:{employeeId}")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  syncedAt       DateTime?

  @@index([locationId])
  @@index([ledgerId])
  @@index([employeeId])
  @@index([sourceType])
  @@index([shiftId])
  @@index([createdAt])
  @@index([locationId, sourceType, createdAt]) // Reports: tip-outs by type + date range
  @@index([locationId, employeeId, createdAt]) // Employee tip history lookups
  @@index([locationId, type, sourceType, createdAt])
  @@index([locationId, updatedAt])
}

model TipTransaction {
  id                String                   @id @default(cuid())
  locationId        String
  location          Location                 @relation(fields: [locationId], references: [id])
  orderId           String
  order             Order                    @relation("TipTransactionOrder", fields: [orderId], references: [id])
  paymentId         String?
  payment           Payment?                 @relation("TipTransactionPayment", fields: [paymentId], references: [id])
  tipGroupId        String?
  tipGroup          TipGroup?                @relation("TipTransactionGroup", fields: [tipGroupId], references: [id])
  segmentId         String?
  segment           TipGroupSegment?         @relation(fields: [segmentId], references: [id])
  amountCents       Decimal                  @db.Decimal(10, 2)
  sourceType        TipTransactionSourceType
  kind              String                   @default("tip") // Skill 277: 'tip' | 'service_charge' | 'auto_gratuity'
  collectedAt       DateTime
  primaryEmployeeId String?
  primaryEmployee   Employee?                @relation("TipTransactionEmployee", fields: [primaryEmployeeId], references: [id])
  ccFeeAmountCents  Decimal                  @default(0) @db.Decimal(10, 2)
  idempotencyKey    String?                  @unique // Skill 274: dedup guard (e.g. "tip-txn:{orderId}:{paymentId}")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?

  @@index([locationId])
  @@index([orderId])
  @@index([tipGroupId])
  @@index([collectedAt])
  @@index([locationId, updatedAt])
}

// ============================================
// TIP GROUP TEMPLATES (Admin-defined team pools)
// ===============================================

model TipGroupTemplate {
  id               String            @id @default(cuid())
  locationId       String
  location         Location          @relation(fields: [locationId], references: [id])
  name             String // "Downstairs Servers", "Bar Team", etc.
  allowedRoleIds   Json // Array of role IDs that can join this team
  defaultSplitMode TipGroupSplitMode @default(equal)
  active           Boolean           @default(true)
  sortOrder        Int               @default(0)

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  syncedAt      DateTime?

  tipGroups TipGroup[] // Runtime group instances for this template

  @@index([locationId])
  @@index([active])
}

// TIP GROUPS (Skill 252 - Dynamic Tip Groups)
// ============================================

model TipGroup {
  id                String            @id @default(cuid())
  locationId        String
  location          Location          @relation(fields: [locationId], references: [id])
  createdBy         String // Employee who started the group
  createdByEmployee Employee          @relation("TipGroupCreatedBy", fields: [createdBy], references: [id])
  ownerId           String // Current owner (for approvals)
  owner             Employee          @relation("TipGroupOwner", fields: [ownerId], references: [id])
  registerId        String? // Terminal/register
  register          Terminal?         @relation("TipGroupRegister", fields: [registerId], references: [id])
  templateId        String? // Links to admin-defined TipGroupTemplate (null = ad-hoc group)
  template          TipGroupTemplate? @relation(fields: [templateId], references: [id])
  startedAt         DateTime          @default(now())
  endedAt           DateTime?
  status            TipGroupStatus    @default(active)
  splitMode         TipGroupSplitMode @default(equal)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  syncedAt          DateTime?

  memberships TipGroupMembership[]
  segments    TipGroupSegment[]

  // C-SCHEMA-1: Added reverse relations
  clockEntries TimeClockEntry[] @relation("ClockEntryTipGroup")

  // C-SCHEMA-1: Reverse relations (batch 2)
  tipTransactions TipTransaction[] @relation("TipTransactionGroup")

  @@index([locationId])
  @@index([status])
  @@index([startedAt])
  @@index([ownerId])
  @@index([templateId])
}

model TipGroupMembership {
  id         String                   @id @default(cuid())
  locationId String
  location   Location                 @relation(fields: [locationId], references: [id])
  groupId    String
  group      TipGroup                 @relation(fields: [groupId], references: [id])
  employeeId String
  employee   Employee                 @relation(fields: [employeeId], references: [id])
  joinedAt   DateTime                 @default(now())
  leftAt     DateTime?
  role       String? // For role-weighted splits
  approvedBy String? // Owner who approved join
  status     TipGroupMembershipStatus @default(active)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  deletedAt  DateTime?
  syncedAt   DateTime?

  @@index([groupId])
  @@index([employeeId])
  @@index([status])
  @@index([locationId])
  @@index([locationId, status])
}

model TipGroupSegment {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  groupId     String
  group       TipGroup  @relation(fields: [groupId], references: [id])
  startedAt   DateTime
  endedAt     DateTime?
  memberCount Int
  splitJson   Json // { "emp1": 0.5, "emp2": 0.5 }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  syncedAt    DateTime?

  // C-SCHEMA-1: Reverse relations (batch 2)
  tipTransactions TipTransaction[]

  @@index([groupId])
  @@index([startedAt])
  @@index([locationId])
}

// ============================================
// TIP DEBT (Skill 278 - Chargeback Remainder)
// ============================================

model TipDebt {
