  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  courseNumber  Int // 1, 2, 3, 4, 5
  name          String // "Appetizers", "Soup/Salad", "Entrees", "Dessert", "After-Dinner"
  displayName   String? // Optional custom display name
