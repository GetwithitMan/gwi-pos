  modifierBytes     String?
  trailerBytes      String?
  parseStatus       BergParseStatus
  lrcReceived       String
  lrcCalculated     String
  lrcValid          Boolean
  status            BergDispenseStatus
  unmatchedType     String?
  pourSizeOz        Decimal?              @db.Decimal(6, 3)
  pourCost          Decimal?              @db.Decimal(10, 2)
  orderId           String?
  orderItemId       String?
  employeeId        String?
  terminalId        String?
  ackLatencyMs      Int?
  ackTimeoutMs      Int
  errorReason       String?
  businessDate      DateTime?
  idempotencyKey    String                @unique
  receivedAt        DateTime              @default(now())
  acknowledgedAt    DateTime?
  variantKey        String?
  variantLabel      String?
