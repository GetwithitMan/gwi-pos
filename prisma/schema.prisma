// ─── Card Detection (Passive Card Detection — Always-Listening) ─────────────
// Short-lived audit/resolution store for passive card reads. Server-side only.
// recordNo scrubbed after 24h, rows deleted after 30d.

model CardDetection {
  id                   String    @id @default(cuid())
  detectionId          String    @unique // UUID from detection
  readerId             String
  terminalId           String
  sessionId            String
  recordNo             String? // Datacap vault token (scrubbed after 24h)
  cardType             String?
  cardLast4            String?
  cardholderName       String?
  entryMethod          String?
  walletType           String?
  matchKind            String // 'open_tab_found' | 'no_open_tab' | 'ambiguous'
  matchedOrderId       String?
  decisionExpiresAt    DateTime
  status               String    @default("pending") // pending | resolved | expired | suppressed
  actionTaken          String? // open_tab | save_card | view_tab | dismissed
  actionResult         String? // success | failed | expired
  resolvedAt           DateTime?
  resolvedByUserId     String?
  resolvedByTerminalId String?
  leaseVersion         Int?
  suppressedReason     String? // duplicate_window | dismiss_cooldown
  errorCode            String?
  promptShownAt        DateTime?
  promptDismissedAt    DateTime?
  locationId           String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([readerId, createdAt(sort: Desc)])
  @@index([terminalId, createdAt(sort: Desc)])
  @@index([status, decisionExpiresAt])
  @@index([matchedOrderId, createdAt(sort: Desc)])
  @@index([locationId, detectionId])
}

