// ============================================
// MENU PROGRAMMING (Skill 03)
// ============================================

model Category {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  name        String
  displayName String?
  description String?
  color       String?
  imageUrl    String?

  // Category Type - controls item builder, modifier filtering, and reporting
  categoryType CategoryType @default(food)

  // Display
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  showOnPOS  Boolean @default(true)
  showOnline Boolean @default(true)

  // Bartender View - which menu section this category appears in
  categoryShow CategoryShow @default(all)

  // Kitchen routing
  prepStationId String?
  prepStation   PrepStation? @relation(fields: [prepStationId], references: [id])
  courseNumber  Int?

  // Printer routing - printers for items in this category
  // JSON array of printer IDs, e.g., ["printer-1", "printer-2"]
  // TODO: JSON array cannot enforce FK constraints on Printer. Consider migrating to a relation table (CategoryPrinter) for referential integrity.
  printerIds Json?

  // Tag-based routing (Routing Engine) - inherited by items in this category
  // JSON array of route tags, e.g., ["grill", "made-to-order"]
  routeTags Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  menuItems MenuItem[]

  // Print routing rules for this category
  printRules PrintRule[]

  // @@index([locationId]) — removed: redundant with compound indexes below

  @@unique([locationId, name])
  @@index([prepStationId])
  @@index([sortOrder])
  @@index([categoryType])
  @@index([locationId, isActive, deletedAt])
  @@index([locationId, sortOrder])
  @@index([locationId, updatedAt]) // Delta sync: { locationId, updatedAt: { gt: since } }
}

model MenuItem {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Identity
  name        String
  displayName String?
  description String?
  sku         String?
  imageUrl    String?

  // Pricing
  price       Decimal  @db.Decimal(10, 2) // Cash price (or base price if no dual pricing)
  priceCC     Decimal? @db.Decimal(10, 2) // Credit card price (for dual pricing)
  cost        Decimal? @db.Decimal(10, 2) // For profit tracking
  onlinePrice Decimal? @db.Decimal(10, 2) // Online ordering price override (null = use POS price)

  // Tax
  taxRate     Decimal? @db.Decimal(10, 4) // Override location default
  isTaxExempt Boolean  @default(false)

  // Display & Behavior
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  showOnPOS  Boolean @default(true)
  showOnline Boolean @default(true)

  // Kitchen
  prepStationId String? // Override category station
  prepStation   PrepStation? @relation(fields: [prepStationId], references: [id])
  prepTime      Int? // Minutes
  courseNumber  Int? // Override category course

  // Printer routing - override category's printers for this item
  // JSON array of printer IDs, e.g., ["printer-1", "printer-2"]
  // TODO: JSON array cannot enforce FK constraints on Printer. Consider migrating to a relation table for referential integrity.
  printerIds       Json?
  backupPrinterIds Json? // Backup printers if primary fails

  // Tag-based routing (Routing Engine) - overrides category's routeTags if set
  // JSON array of route tags, e.g., ["pizza", "expo-only"]
  routeTags Json?

  // Inventory
  trackInventory Boolean @default(false)
  currentStock   Int?
  lowStockAlert  Int?
  isAvailable    Boolean @default(true) // 86'd when false

  // Type
  itemType MenuItemType @default(standard)

  // Combo Print Mode - how combo components print to stations
  // 'individual' - Each component follows its own print rules (burger→kitchen, drink→bar)
  // 'primary' - Entire combo prints to the combo's assigned printer
  // 'all' - Full combo ticket prints at ALL relevant stations
  comboPrintMode String? // null for non-combos, 'individual' | 'primary' | 'all'

  // Timed Rental Pricing (Skill 81) - for pool tables, dart boards, etc.
  timedPricing     Json? // { per15Min: 5.00, per30Min: 8.00, perHour: 15.00, minimum: 15 }
  // Per-minute pricing (replaces timedPricing JSON)
  ratePerMinute    Decimal? @db.Decimal(10, 2) // e.g., 0.25 = $0.25/min
  minimumCharge    Decimal? @db.Decimal(10, 2) // e.g., 15.00 = $15 minimum
  incrementMinutes Int?     @default(15) // Charges in blocks after minimum
  minimumMinutes   Int? // Minimum rental time in minutes
  graceMinutes     Int? // Grace period before next increment

  // Prepaid packages - discounted upfront deals
  // Format: [{ minutes: 30, price: 10, label: "30 Min Deal" }, { minutes: 60, price: 15, label: "1 Hour Special" }]
  prepaidPackages Json?

  // Happy Hour - automatic time-based discounts
  happyHourEnabled  Boolean? @default(false)
  happyHourDiscount Int?     @default(50) // Percentage off (50 = 50% off)
  happyHourStart    String? // "13:00" (1 PM in 24h format)
  happyHourEnd      String? // "16:00" (4 PM in 24h format)
  happyHourDays     Json? // ["monday", "tuesday", "wednesday", "thursday", "friday"]

  // Overtime pricing
  overtimeEnabled       Boolean? @default(false)
  overtimeMode          String? // 'multiplier' | 'custom_rate' | 'flat_fee' | 'per_minute'
  overtimeMultiplier    Decimal? @db.Decimal(10, 4) // e.g., 1.5, 2.0 — scales base rate
  overtimePerMinuteRate Decimal? @db.Decimal(10, 2) // custom per-minute rate in dollars
  overtimeFlatFee       Decimal? @db.Decimal(10, 2) // flat fee charged for any overtime
  overtimeGraceMinutes  Int?     @default(5) // grace before overtime kicks in

  // Entertainment tracking (Skill 94-97)
  entertainmentStatus String? // 'available', 'in_use', 'maintenance'
  currentOrderId      String? // Links to order currently using this item
  currentOrder        Order?     @relation("MenuItemCurrentOrder", fields: [currentOrderId], references: [id])
  currentOrderItemId  String? // Links to specific order item
  currentOrderItem    OrderItem? @relation("MenuItemCurrentOrderItem", fields: [currentOrderItemId], references: [id])
  blockTimeMinutes    Int? // If set, sells in blocks (30, 60, 90 mins)
  maxConcurrentUses   Int?       @default(1) // For items with multiple units
  currentUseCount     Int?       @default(0) // Current number in use

  // Menu Scheduling (Skill 40)
  availableFrom String? // Time format "HH:mm" e.g., "06:00"
  availableTo   String? // Time format "HH:mm" e.g., "11:00"
  availableDays String? // Comma-separated days: "0,1,2,3,4,5,6" (0=Sunday)

  // Seasonal date-based availability (date range, not time-of-day)
  availableFromDate  DateTime? // Item becomes visible on this date
  availableUntilDate DateTime? // Item becomes hidden after this date

  // Commission (Skill 29)
  commissionType  String? // 'fixed' | 'percent' | null
  commissionValue Decimal? @db.Decimal(10, 2)

  // Liquor Pour Sizes - quick pricing options for liquor items
  // Stores enabled pour sizes and their multipliers: { shot: 1.0, double: 2.0, tall: 1.5, short: 0.75 }
  pourSizes            Json?
  defaultPourSize      String? // Default selection: 'shot', 'double', 'tall', 'short'
  applyPourToModifiers Boolean @default(false) // Apply pour multiplier to spirit modifiers too

  // Weight-Based Selling (Scale Integration)
  soldByWeight       Boolean  @default(false) // Item sold by weight instead of quantity
  weightUnit         String? // "lb" | "kg" | "oz" | "g"
  pricePerWeightUnit Decimal? @db.Decimal(10, 2) // Price per weight unit (e.g. 5.99/lb)

  // Customer-Facing Display (CFD) - featured items shown on idle screen
  isFeaturedCfd Boolean @default(false)

  // Fulfillment routing (HA cellular)
  fulfillmentType      FulfillmentType @default(KITCHEN_STATION)
  fulfillmentStationId String?

  // Allergen tracking — array of allergen tags (e.g., ["Milk", "Eggs", "Gluten"])
  allergens String[] @default([])

  // Age verification — flag for items requiring age check (alcohol, tobacco, etc.)
  isAgeRestricted Boolean @default(false)

  // Force-open modifier modal on every tap, even when no required modifiers exist
  alwaysOpenModifiers Boolean @default(false)

  // Tip-exempt — item amount excluded from tip suggestion calculations
  tipExempt Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  // Relations
  ownedModifierGroups      ModifierGroup[]           @relation("ItemModifierGroups") // Item-specific modifier groups
  orderItems               OrderItem[]
  comboComponentItems      ComboComponent[]          @relation("ComboComponentItem")
  comboComponentDefaults   ComboComponent[]          @relation("ComboComponentDefault")
  comboOptions             ComboComponentOption[]
  orderItemComboSelections OrderItemComboSelection[]

  // Liquor Builder - Recipe ingredients for cocktails
  recipeIngredients RecipeIngredient[]

  // Direct link to bottle product (for spirit items like "Patron Silver" on the menu)
  // This enables bottles to be the source of truth for liquor menu items
  linkedBottleProductId String?
  linkedBottleProduct   BottleProduct? @relation("LinkedBottleMenuItems", fields: [linkedBottleProductId], references: [id])
  linkedPourSizeOz      Decimal?       @db.Decimal(6, 3) // Custom pour size override for linked bottle (oz)

  // Modifiers that link to this item (for spirit upgrades, etc.)
  linkedModifiers Modifier[] @relation("LinkedModifierItem")

  // Menu Item Ingredients - what's in this item
  ingredients MenuItemIngredient[]

  // Recipe costing (Skill 115)
  recipe MenuItemRecipe?

  // Print routing rules for this specific item
  printRules PrintRule[]

  // Pizza Builder - specialty pizza configuration
  pizzaSpecialty PizzaSpecialty?

  // Floor Plan Elements linked to this item (for entertainment items)
  floorPlanElements FloorPlanElement[]

  // C-SCHEMA-1: Reverse relations
  comboTemplates        ComboTemplate[]        @relation("ComboTemplateMenuItem")
  timedTables           Table[]                @relation("TableTimedItem")
  timedSessions         TimedSession[]         @relation("TimedSessionMenuItem")
  inventoryTransactions InventoryTransaction[]
  stockAlerts           StockAlert[]

  // C-SCHEMA-1: Reverse relations (batch 2)
  coupons Coupon[] @relation("CouponFreeItem")

  // Pricing Options (per-item size/variant pricing groups)
  pricingOptionGroups PricingOptionGroup[]

  // Barcode scanning
  barcodes ItemBarcode[]

  metadata Json? // Cake builder config (quickPick, capacityWeight, defaultTiers), future extensibility

  @@unique([locationId, sku])
  // @@index([locationId]) — removed: redundant with compound indexes below
  @@index([categoryId])
  @@index([prepStationId])
  @@index([isActive, showOnPOS])
  @@index([locationId, isActive, deletedAt])
  @@index([locationId, isActive])
  @@index([locationId, categoryId])
  @@index([locationId, updatedAt]) // Delta sync: { locationId, updatedAt: { gt: since } }
}

model ModifierGroup {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  // NEW: Item ownership - each modifier group belongs to ONE specific menu item
  // This enables per-item reporting and customization without affecting other items
  menuItemId String?
  menuItem   MenuItem? @relation("ItemModifierGroups", fields: [menuItemId], references: [id], onDelete: Cascade)

  name        String
  displayName String?

  // Modifier Types: food, liquor, retail, entertainment, combo, universal (can have multiple)
  modifierTypes Json @default("[\"universal\"]")

  // Requirements
  minSelections    Int     @default(0)
  maxSelections    Int     @default(1)
  isRequired       Boolean @default(false)
  allowStacking    Boolean @default(false) // Allow selecting the same modifier multiple times
  stackDisplayMode String  @default("individual") // "individual" = separate lines, "combined" = "Ranch ×3"

  // Tiered pricing: define pricing tiers based on selection count
  // mode: "flat_tiers" = all selections use tier price, "free_threshold" = first N free then use modifier's own price
  // Example flat_tiers: { "mode": "flat_tiers", "tiers": [{ "upTo": 3, "price": 0 }, { "upTo": 4, "price": 0.75 }, { "upTo": null, "price": 1.50 }] }
  // Example free_threshold: { "mode": "free_threshold", "tiers": [{ "upTo": 3, "price": 0 }] }
  tieredPricingConfig Json?

  // Exclusion: groups with the same key on the same item prevent duplicate modifier selections
  // Example: Side Choice 1 and Side Choice 2 both have exclusionGroupKey: "side-choices"
  exclusionGroupKey String?

  // Online Ordering Override
  hasOnlineOverride Boolean @default(false) // Enable separate modifier management for online orders

  // Display
  sortOrder  Int     @default(0)
  showOnline Boolean @default(true) // Whether this modifier group appears for online ordering

  // Open Entry — allow freeform custom modifiers on POS
  allowOpenEntry      Boolean @default(false)
  // Allow None — show a "None" button on required groups so staff can skip selection
  allowNone           Boolean @default(false)
  // Whether "None" selection prints to kitchen tickets/KDS
  nonePrintsToKitchen Boolean @default(false)
  // Whether "None" selection shows on customer receipts
  noneShowOnReceipt   Boolean @default(false)
  // Auto-advance — auto-dismiss single-select required group after selection
  autoAdvance         Boolean @default(false)

  // Liquor Builder - Spirit Group Configuration
  isSpiritGroup Boolean @default(false)

  // Template origin metadata (audit only — NOT a live link)
  sourceTemplateId   String? // which template this was cloned from
  sourceTemplateName String? // human-readable name at time of apply

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  modifiers Modifier[]

  // Modifiers that use this group as a sub-modifier
  parentModifiers Modifier[] @relation("SubModifier")

  // Combo components that use this modifier group
  comboComponents ComboComponent[]

  // Liquor Builder - Spirit configuration
  spiritConfig SpiritModifierGroup?

  metadata Json? // cakeGroupType (flavor/filling/frosting/decoration/dietary), future extensibility

  @@index([locationId])
  @@index([menuItemId])
}

model Modifier {
  id              String        @id @default(cuid())
  locationId      String
  location        Location      @relation(fields: [locationId], references: [id])
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  name        String
  displayName String?

  // Pricing
  // If linkedMenuItemId is set and price is 0, use linked item's price
  // If price > 0, it acts as a price override or upcharge
  price       Decimal           @default(0) @db.Decimal(10, 2)
  priceType   ModifierPriceType @default(upcharge)
  upsellPrice Decimal?          @db.Decimal(10, 2) // Special price when offered as upsell
  cost        Decimal?          @db.Decimal(10, 2)

  // Pre-modifier support - explicit boolean fields for each option
  // These work just like ingredient pre-mods for consistent inventory tracking
  allowNo     Boolean @default(true)
  allowLite   Boolean @default(false)
  allowOnSide Boolean @default(false)
  allowExtra  Boolean @default(false)
  extraPrice  Decimal @default(0) @db.Decimal(10, 2) // Price when "extra" is selected

  // Per-modifier deduction multipliers (override location-level defaults)
  // null = fall back to location MultiplierSettings (0.5 for lite, 2.0 for extra)
  liteMultiplier  Decimal? @db.Decimal(10, 4) // Multiplier applied when "Lite" selected (default 0.5x)
  extraMultiplier Decimal? @db.Decimal(10, 4) // Multiplier applied when "Extra" selected (default 2.0x)

  // Legacy JSON field - kept for backwards compatibility
  allowedPreModifiers Json? // Array of allowed prefixes: ["no", "lite", "extra", "side"]
  extraUpsellPrice    Decimal? @db.Decimal(10, 2) // Upsell price for "extra"

  // Link to ingredient for inventory deduction
  // When this modifier is ordered, deduct from this ingredient's stock
  ingredientId String?
  ingredient   Ingredient? @relation("ModifierIngredient", fields: [ingredientId], references: [id])

  // Sub-modifier support - when selected, prompts for additional modifiers
  childModifierGroupId String?
  childModifierGroup   ModifierGroup? @relation("SubModifier", fields: [childModifierGroupId], references: [id])

  // Commission (Skill 29)
  commissionType  String? // 'fixed' | 'percent' | null
  commissionValue Decimal? @db.Decimal(10, 2)

  // Linked Menu Item - for spirit upgrades, links to actual menu item for pricing/reporting
  // When set, sales are tracked against this item for reporting purposes
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation("LinkedModifierItem", fields: [linkedMenuItemId], references: [id])

  // Liquor Builder - Spirit fields
  spiritTier            String? // 'well', 'call', 'premium', 'top_shelf'
  linkedBottleProductId String? // Links to bottle inventory
  linkedBottleProduct   BottleProduct? @relation(fields: [linkedBottleProductId], references: [id])
  pourSizeOz            Decimal?       @db.Decimal(6, 3) // Override default pour size

  // Display
  sortOrder Int     @default(0)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  // Channel visibility (for online ordering overrides)
  showOnPOS  Boolean @default(true) // Visible to servers on POS
  showOnline Boolean @default(true) // Visible for online ordering

  // Bar hot button — renders as quick-access button in modifier modal (Neat, Rocks, Up, etc.)
  showAsHotButton Boolean @default(false)

  // Inventory tracking (Skill 115)
  isLabel Boolean @default(false) // True = grouping only, no inventory tracking

  // Printer routing for modifiers
  // printerRouting: "follow" (default) = prints with main item
  //                 "also" = prints with main item AND to printerIds
  //                 "only" = prints ONLY to printerIds (not with main item)
  printerRouting ModifierPrinterRouting @default(follow)
  // TODO: JSON array cannot enforce FK constraints on Printer. Consider migrating to a relation table for referential integrity.
  printerIds     Json? // Array of printer IDs when routing is "also" or "only"

  // Swap — allow substituting this modifier with an alternate item at POS
  swapEnabled              Boolean  @default(false)
  swapTargets              Json? // SwapTarget[] — targets with pricing modes
  customPreModifiers       Json? // CustomPreMod[] — custom pre-modifier options (Well Done, Blackened, etc.)
  // Inventory deduction override
  inventoryDeductionAmount Decimal? @db.Decimal(10, 4) // Amount of ingredient to deduct per selection
  inventoryDeductionUnit   String? // Unit for deduction (oz, ml, unit, g)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  orderItemModifiers OrderItemModifier[]

  // Print routing rules for this specific modifier
  printRules PrintRule[]

  // Inventory link (Skill 115)
  inventoryLink ModifierInventoryLink?

  // C-SCHEMA-1: Reverse relations (batch 2)
  ingredientSwaps OrderItemIngredient[] @relation("IngredientSwapModifier")

  metadata Json? // perTier flag, requiredIngredients for stock tracking, future extensibility

  @@unique([modifierGroupId, name])
  @@index([locationId])
  @@index([modifierGroupId])
  @@index([childModifierGroupId])
  @@index([linkedBottleProductId])
  @@index([linkedMenuItemId])
  @@index([locationId, linkedMenuItemId])
  @@index([locationId, updatedAt])
}

// ============================================
// COMBO MEALS (Skill 59)
// ============================================

model ComboTemplate {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  menuItemId String   @unique // Links to MenuItem with itemType="combo"
  menuItem   MenuItem @relation("ComboTemplateMenuItem", fields: [menuItemId], references: [id])

  basePrice      Decimal  @db.Decimal(10, 2)
  comparePrice   Decimal? @db.Decimal(10, 2) // A la carte total for savings display
  allowUpcharges Boolean  @default(false) // Per-combo opt-in: when false, server forces upchargeApplied = 0

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  components ComboComponent[]

  @@index([locationId])
}

model ComboComponent {
  id              String        @id @default(cuid())
  locationId      String
  location        Location      @relation(fields: [locationId], references: [id])
  comboTemplateId String
  comboTemplate   ComboTemplate @relation(fields: [comboTemplateId], references: [id], onDelete: Cascade)

  slotName    String // "entree", "side", "drink"
  displayName String // "Choose Your Side"
  sortOrder   Int    @default(0)

  isRequired    Boolean @default(true)
  minSelections Int     @default(1)
  maxSelections Int     @default(1)

  // The menu item for this combo slot
  menuItemId String?
  menuItem   MenuItem? @relation("ComboComponentItem", fields: [menuItemId], references: [id])

  // Price override for the item itself (null = use item's default price)
  itemPriceOverride Decimal? @db.Decimal(10, 2)

  // Per-modifier price overrides: { "modifierId": 0.00, ... }
  modifierPriceOverrides Json?

  // Legacy fields (kept for backward compatibility)
  modifierGroupId String?
  modifierGroup   ModifierGroup? @relation(fields: [modifierGroupId], references: [id])
  priceOverride   Decimal?       @db.Decimal(10, 2)
  defaultItemId   String?
  defaultItem     MenuItem?      @relation("ComboComponentDefault", fields: [defaultItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  options ComboComponentOption[]

  // Reverse relation for customer-pick snapshots
  orderItemComboSelections OrderItemComboSelection[]

  @@index([locationId])
  @@index([modifierGroupId])
  @@index([menuItemId])
}

model ComboComponentOption {
  id               String         @id @default(cuid())
  locationId       String
  location         Location       @relation(fields: [locationId], references: [id])
  comboComponentId String
  comboComponent   ComboComponent @relation(fields: [comboComponentId], references: [id], onDelete: Cascade)

  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  upcharge    Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  // Reverse relation for customer-pick snapshots
  orderItemComboSelections OrderItemComboSelection[]

  @@unique([comboComponentId, menuItemId])
  @@index([locationId])
  @@index([menuItemId])
}

/// OrderItemComboSelection — snapshot of one customer pick at order time.
/// INVARIANTS (see docs/features/combos.md):
///  - One row per pick; NO quantity column. "4 Bud" = 4 rows with distinct sortIndex.
///  - Snapshot fields (menuItemId, optionName, upchargeApplied) survive admin edits to templates.
///  - comboComponentId/comboComponentOptionId are soft refs with onDelete: SetNull — history persists.
///  - When OrderItem.deletedAt is set, children are implicitly ignored downstream.
model OrderItemComboSelection {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // Soft references to the template rows that produced this pick (nullable; survive admin delete-recreate).
  comboComponentId       String?
  comboComponent         ComboComponent?       @relation(fields: [comboComponentId], references: [id], onDelete: SetNull)
  comboComponentOptionId String?
  comboComponentOption   ComboComponentOption? @relation(fields: [comboComponentOptionId], references: [id], onDelete: SetNull)

  // Required snapshot fields — always populated at pick time.
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  optionName      String // At-pick-time display name snapshot
  upchargeApplied Decimal  @default(0) @db.Decimal(10, 2) // 0 when template.allowUpcharges=false
  sortIndex       Int      @default(0) // Deterministic receipt/print ordering

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  // HA cellular sync — mutation origin tracking (matches OrderItem pattern)
  lastMutatedBy String?

  @@index([orderItemId])
  @@index([locationId])
  @@index([menuItemId])
  @@index([orderItemId, sortIndex])
  @@index([comboComponentId])
}

// ============================================
// TABLES & FLOOR PLAN (Skill 55)
// ============================================

model Section {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  name  String // "Bar", "Patio", "Main Floor"
  color String?

  // Floor plan (Skill 80)
  posX        Int    @default(0)
  posY        Int    @default(0)
  width       Int    @default(400)
  height      Int    @default(300)
  shape       String @default("rectangle") // rectangle, polygon
  coordinates Json? // For polygon: [{x, y}, {x, y}, ...]

  // Floor plan dimensions in feet (for editor grid snapping)
  // Float is acceptable here — display coordinates, no financial precision needed
  widthFeet    Float @default(40) // Room width in feet
  heightFeet   Float @default(30) // Room height in feet
  gridSizeFeet Float @default(0.25) // Grid snap size in feet (0.25 = 3 inch)

  sortOrder Int     @default(0)
  isVisible Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  tables            Table[]             @relation("TableSection")
  assignments       SectionAssignment[]
  floorPlanElements FloorPlanElement[]

  // C-SCHEMA-1: Reverse relations (batch 2)
  defaultForTables Table[]          @relation("TableDefaultSection")
  scheduledShifts  ScheduledShift[] @relation("ScheduledShiftSection")

  @@unique([locationId, name])
  @@index([locationId])
}

model SectionAssignment {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  @@index([locationId])
  @@index([sectionId])
  @@index([employeeId])
  @@index([sectionId, unassignedAt, deletedAt])
}

model Table {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  sectionId  String?
  section    Section? @relation("TableSection", fields: [sectionId], references: [id])

  name         String // "Table 1", "Bar 3", "Patio A"
  abbreviation String? // Short display name for floor plan: "T1", "B3", "PA"
  capacity     Int     @default(4) // DEPRECATED: Use _count.seats or seats.length instead
  // ⚠️ This field can drift from actual seat count. Always use seatCount from API responses.

  // Floor plan position (Skill 80)
  posX        Int    @default(0)
  posY        Int    @default(0)
  width       Int    @default(80)
  height      Int    @default(80)
  rotation    Int    @default(0) // Degrees 0-359
  shape       String @default("rectangle") // rectangle, circle, square, booth, bar
  seatPattern String @default("all_around") // all_around, front_only, three_sides, two_sides, inside

  // For timed rentals (pool tables, dart boards)
  isTimedRental Boolean   @default(false)
  timedItemId   String? // Links to MenuItem for pricing
  timedItem     MenuItem? @relation("TableTimedItem", fields: [timedItemId], references: [id])

  // Status
  status   TableStatus @default(available)
  isActive Boolean     @default(true)

  // Default layout (admin-defined, used for reset-to-default)
  // Set via "Save as Default Layout" button in floor plan admin
  defaultPosX      Int? // Admin-defined default X position
  defaultPosY      Int? // Admin-defined default Y position
  defaultSectionId String? // Admin-defined default section
  defaultSection   Section? @relation("TableDefaultSection", fields: [defaultSectionId], references: [id])

  // Locked items (T019) - bolted down furniture that cannot be moved
  isLocked Boolean @default(false)

  // Optimistic locking (B8) — prevents concurrent edit races
  version Int @default(0)

  // Reservation Engine — table capacity & scheduling
  minCapacity             Int     @default(1)
  maxCapacity             Int?
  isReservable            Boolean @default(true)
  combinableWithTableIds  Json    @default("[]")
  turnTimeOverrideMinutes Int?
  priority                Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  orders                Order[]
  reservations          Reservation[]
  timedSessions         TimedSession[]
  seats                 Seat[]
  tickets               Ticket[]
  eventConfigurations   EventTableConfig[]
  sourceTableOrderItems OrderItem[]             @relation("SourceTableOrderItems") // Items ordered from this table (virtual combine T-S notation)
  entertainmentWaitlist EntertainmentWaitlist[]
  reservationTables     ReservationTable[]

  // @@index([locationId]) — removed: redundant with compound indexes below

  // C-SCHEMA-1: Reverse relations (batch 2)
  errorLogs ErrorLog[] @relation("ErrorLogTable")

  @@unique([locationId, name])
  @@index([sectionId])
  // @@index([status]) — removed: redundant with @@index([locationId, status]) (all queries include locationId)
  @@index([locationId, status])
  @@index([locationId, isActive, deletedAt])
  @@index([locationId, sectionId])
  @@index([locationId, updatedAt]) // Delta sync: { locationId, updatedAt: { gt: since } }
}

// ============================================
// FLOOR PLAN ELEMENTS (Entertainment, Decorations)
// ============================================

model FloorPlanElement {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  sectionId  String?
  section    Section? @relation(fields: [sectionId], references: [id])

  name         String // "Pool Table 1", "Dartboard A"
  abbreviation String? // Short display name: "PT1", "DB-A"

  // Element classification
  elementType FloorPlanElementType @default(entertainment)
  visualType  String // "pool_table", "dartboard", "arcade", "foosball", "shuffleboard", etc.

  // Link to menu item (for entertainment items with pricing/sessions)
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation(fields: [linkedMenuItemId], references: [id])

  // Position & dimensions (in pixels, for rectangle/circle elements)
  posX     Int @default(100)
  posY     Int @default(100)
  width    Int @default(120)
  height   Int @default(80)
  rotation Int @default(0)

  // Geometry in feet (for wall/line elements, replaces posX/posY for lines)
  // JSON: { "type": "line", "start": { "x": 0, "y": 0 }, "end": { "x": 10, "y": 0 } }
  // Or: { "type": "rectangle", "x": 0, "y": 0, "width": 5, "height": 3 }
  // Or: { "type": "circle", "x": 5, "y": 5, "radius": 2 }
  geometry  Json?
  // Float is acceptable for thickness/opacity — display values, no financial precision needed
  thickness Float @default(0.5) // Wall thickness in feet

  // Visual customization
  fillColor   String? // Override default SVG fill
  strokeColor String? // Override default SVG stroke
  opacity     Float   @default(1.0)

  // Status (for entertainment)
  status           FloorPlanElementStatus @default(available)
  currentOrderId   String? // Active order using this element
  currentOrder     Order?                 @relation("FloorPlanCurrentOrder", fields: [currentOrderId], references: [id])
  sessionStartedAt DateTime?
  sessionExpiresAt DateTime?

  sortOrder Int     @default(0)
  isVisible Boolean @default(true)
  isLocked  Boolean @default(false) // Prevent moving

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  waitlistEntries EntertainmentWaitlist[]

  @@index([locationId])
  @@index([sectionId])
  @@index([linkedMenuItemId])
  @@index([status])
  @@index([locationId, elementType, isVisible])
}

model EntertainmentWaitlist {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  // Can be for a specific element OR any element of a type
  elementId  String? // Specific element (e.g., "Pool Table 2")
  element    FloorPlanElement? @relation(fields: [elementId], references: [id])
  visualType String? // OR any of this type (e.g., "any pool_table")

  // Who's waiting
  tableId      String? // Table that's waiting
  table        Table?  @relation(fields: [tableId], references: [id])
  customerName String? // Walk-in name
  partySize    Int     @default(1)
  phone        String? // For SMS notification

  // Status
  status      EntertainmentWaitlistStatus @default(waiting)
  position    Int                         @default(0) // Queue position
  requestedAt DateTime                    @default(now())
  notifiedAt  DateTime?
  seatedAt    DateTime?
  expiresAt   DateTime? // Auto-expire after X minutes if not claimed

  notes String?

  // Deposit
  depositAmount      Decimal?  @db.Decimal(10, 2) // Amount held (in dollars)
  depositMethod      String? // 'cash' | 'card'
  depositRecordNo    String? // Datacap token for card pre-auth
  depositCardLast4   String?
  depositCardBrand   String?
  depositStatus      String? // 'collected' | 'applied' | 'refunded' | 'forfeited'
  depositCollectedBy String? // Employee ID who collected
  depositRefundedAt  DateTime?

  lastMutatedBy String? // 'cloud' | 'local' | null
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  syncedAt      DateTime?

  @@index([locationId])
  @@index([elementId])
  @@index([visualType])
  @@index([status])
}

// ============================================
// ENTERTAINMENT SESSIONS (Timed Rental State Machine)
// ============================================

model EntertainmentSession {
  id                  String   @id @default(cuid())
  locationId          String
  location            Location @relation(fields: [locationId], references: [id])
  orderItemId         String   @unique
  orderItem           OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  orderId             String
  order               Order @relation(fields: [orderId], references: [id], onDelete: Restrict)
  resourceId          String

  sessionState        EntertainmentSessionState @default(pre_start)
  version             Int @default(1)

  scheduledMinutes    Int?
  startedAt           DateTime?
  bookedEndAt         DateTime?
  stoppedAt           DateTime?
  overtimeStartedAt   DateTime?
  lastExtendedAt      DateTime?
  totalExtendedMinutes Int @default(0)

  pricingSnapshot     Json?
  finalPriceCents     Int?
  finalPriceDollars   Decimal? @db.Decimal(10, 2)

  createdBy           String?
  stoppedBy           String?
  stopReason          String?
  sourceTerminalId    String?

  lastMutatedBy       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?
  syncedAt            DateTime?

  events              EntertainmentSessionEvent[]

  @@index([locationId])
  @@index([orderId])
  @@index([resourceId])
  @@index([sessionState])
  @@index([locationId, sessionState])
}

model EntertainmentSessionEvent {
  id              String   @id @default(cuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  sessionId       String
  session         EntertainmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  eventType       EntertainmentSessionEventType
  payload         Json?
  actorId         String?
  idempotencyKey  String?

  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([locationId, createdAt])
  @@unique([sessionId, idempotencyKey])
}

model EntertainmentResource {
  id                      String   @id @default(cuid())
  locationId              String
  location                Location @relation(fields: [locationId], references: [id])

  name                    String
  resourceType            String
  capacity                Int @default(1)
  sortOrder               Int @default(0)
  status                  String @default("available")

  linkedMenuItemId        String?
  linkedFloorPlanElementId String?

  activeSessionId         String? @unique

  isBookable              Boolean @default(true)
  defaultPricingPolicyId  String?

  lastMutatedBy           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  deletedAt               DateTime?
  syncedAt                DateTime?

  @@unique([locationId, name])
  @@index([locationId])
  @@index([linkedMenuItemId])
  @@index([linkedFloorPlanElementId])
  @@index([status])
}

// ============================================
// ORDER TYPES (Configurable Order Workflow)
// ============================================

model OrderType {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  name        String // "Dine In", "Call-in", "Drive-through"
  slug        String // "dine_in", "call_in", "drive_through" (code reference)
  description String?
  color       String? // Badge color (hex)
  icon        String? // Icon name (e.g., "table", "phone", "car")
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false) // True for built-in types (dine_in, bar_tab, takeout)
  allowTips   Boolean @default(true) // false for cake_deposit_settlement, true for cake_balance_settlement

  // JSON Configuration Fields
  // Required fields: { "tableId": true, "tabName": true, "phone": true }
  requiredFields Json?

  // Optional fields: { "address": true, "pickupTime": true, "vehicleType": true }
  optionalFields Json?

  // Field definitions with labels, types, validation
  // { "phone": { "label": "Phone Number", "type": "phone", "placeholder": "555-123-4567" } }
  fieldDefinitions Json?

  // Workflow rules: { "requirePaymentBeforeSend": true, "requireTableSelection": true }
  workflowRules Json?

  // KDS display configuration: { "badgeText": "{customerName}", "showPickupTime": true }
  kdsConfig Json?

  // Kitchen ticket print formatting
  printConfig Json?

  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  @@unique([locationId, slug])
  @@index([locationId])
  @@index([sortOrder])
  @@index([locationId, updatedAt]) // Delta sync: { locationId, updatedAt: { gt: since } }
}

// ============================================
// ORDERS (Skill 04)
// ============================================

/// ACTIVE: Primary order table — all reads and writes go here.
/// Mutations MUST also emit events via emitOrderEvent() for the OrderSnapshot projection.
/// Order is the source of truth; OrderSnapshot is a materialized read-optimized view.
model Order {
  id         String    @id @default(cuid())
  locationId String
  location   Location  @relation(fields: [locationId], references: [id])
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  // Customer tracking (Skill 51)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Order identification
  orderNumber   Int // Sequential per location per day
  displayNumber String? // Displayed number (e.g., "A23")

  // Split order tracking
  parentOrderId String? // If this is a split, reference to parent
  parentOrder   Order?  @relation("OrderSplits", fields: [parentOrderId], references: [id])
  splitOrders   Order[] @relation("OrderSplits")
  splitIndex    Int? // 1, 2, 3... for display as "31-1", "31-2"

  // Split semantics (Unified Split Checks — Phase 1)
  splitClass        String?   @map("splitClass") // 'structural' | 'allocation' | null (not a split child)
  splitMode         String?   @map("splitMode") // 'by_item' | 'by_seat' | 'by_table' | 'even' | 'custom_amount' | null
  splitFamilyRootId String?   @map("splitFamilyRootId") // Authoritative family root for balance/closure
  splitFamilyTotal  Decimal?  @map("splitFamilyTotal") // Immutable family ceiling; authoritative on family root ONLY
  splitResolution   String?   @map("splitResolution") // null | 'superseded' | 'merged_back' | 'merged_into_other'
  supersededBy      String?   @map("supersededBy") // Order ID that absorbed this child's remaining balance
  supersededAt      DateTime? @map("supersededAt")

  // Split family self-relation
  splitFamilyRoot    Order?  @relation("SplitFamilyRoot", fields: [splitFamilyRootId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  splitFamilyMembers Order[] @relation("SplitFamilyRoot")

  // Type & Context
  orderType    String     @default("dine_in") // Legacy: dine_in, takeout, delivery, bar_tab
  orderTypeId  String? // New: Reference to configurable OrderType
  orderTypeRef OrderType? @relation(fields: [orderTypeId], references: [id])
  tableId      String?
  table        Table?     @relation(fields: [tableId], references: [id])
  guestCount   Int        @default(1)

  // Atomic Seat Management (Skill 121)
  baseSeatCount  Int   @default(1) // Original seat count when order opened
  extraSeatCount Int   @default(0) // Additional seats added (can be negative if removed)
  seatVersion    Int   @default(0) // Monotonic counter for concurrency control
  seatTimestamps Json? // When each seat was added: { "1": "2026-02-01T10:00:00Z", ... }

  tabName     String? // For bar tabs (auto-filled from cardholder name on chip)
  tabNickname String? // Editable display name (e.g., "John S - Beard")
  tabStatus   TabStatus? // null = not a tab

  // Custom fields collected for this order type (e.g., phone, pickupTime, vehicleColor)
  customFields Json?

  // Status
  status OrderStatus @default(open)

  // Concurrency control (optimistic locking for multi-terminal conflict detection)
  version Int @default(1)

  // Timing
  openedAt DateTime  @default(now())
  sentAt   DateTime?
  paidAt   DateTime?
  closedAt DateTime?

  // Reopen tracking (for closed orders that are reopened)
  reopenedAt   DateTime?
  reopenedBy   String? // Employee ID who reopened
  reopenReason String?

  // Denormalized counts
  itemCount Int @default(0)

  // Totals
  subtotal         Decimal  @default(0) @db.Decimal(10, 2)
  discountTotal    Decimal  @default(0) @db.Decimal(10, 2)
  taxTotal         Decimal  @default(0) @db.Decimal(10, 2)
  taxFromInclusive Decimal  @default(0) @db.Decimal(10, 2) // Tax backed out of inclusive items
  taxFromExclusive Decimal  @default(0) @db.Decimal(10, 2) // Tax added on top of exclusive items
  inclusiveTaxRate Decimal  @default(0) @db.Decimal(10, 4) // Inclusive tax rate snapshot at order creation (survives setting changes)
  exclusiveTaxRate Decimal? @db.Decimal(10, 4) // Exclusive tax rate snapshot at creation (null = use live rate)
  tipTotal         Decimal  @default(0) @db.Decimal(10, 2)
  donationAmount   Decimal? @db.Decimal(10, 2) // Optional donation added to order
  total            Decimal  @default(0) @db.Decimal(10, 2)

  // Dual Pricing (Skill 31)
  primaryPaymentMethod String? // 'cash' | 'card' - determines which price applies

  // Commission (Skill 29)
  commissionTotal Decimal @default(0) @db.Decimal(10, 2)

  // Convenience Fee (Payment & Pricing Redesign)
  convenienceFee Decimal? @db.Decimal(10, 2) // Per-channel convenience fee (not in tip basis)

  // Notes
  notes String?

  // Bar Tab Pre-auth (Skill 21)
  preAuthId        String? // Reference to pre-auth transaction
  preAuthAmount    Decimal?       @db.Decimal(10, 2)
  preAuthLast4     String? // Last 4 digits of held card
  preAuthCardBrand String? // Visa, Mastercard, etc.
  preAuthExpiresAt DateTime? // When the hold expires
  preAuthRecordNo  String? // Datacap RecordNo token for capture/increment
  preAuthReaderId  String? // Which reader did the pre-auth
  preAuthReader    PaymentReader? @relation("OrderPreAuthReader", fields: [preAuthReaderId], references: [id])

  // Bottle Service (Phase 10)
  isBottleService           Boolean            @default(false)
  bottleServiceTierId       String? // Linked tier
  bottleServiceTier         BottleServiceTier? @relation("OrderBottleServiceTier", fields: [bottleServiceTierId], references: [id])
  bottleServiceDeposit      Decimal?           @db.Decimal(10, 2) // Deposit amount pre-authorized
  bottleServiceMinSpend     Decimal?           @db.Decimal(10, 2) // Minimum spend requirement (from tier at time of creation)
  bottleServiceCurrentSpend Decimal?           @default(0) @db.Decimal(10, 2) // Denormalized: mirrors subtotal for bottle service orders (avoids re-computation in snapshot)
  incrementAuthFailed       Boolean            @default(false) // True when IncrementalAuth was declined — surfaces amber warning to staff

  // Walkout Recovery (Phase 6)
  isWalkout       Boolean   @default(false)
  walkoutAt       DateTime?
  walkoutMarkedBy String? // Employee who marked as walkout

  // Tab Rollover & Declined Capture
  rolledOverAt      DateTime? // Set when order crosses business day boundary
  rolledOverFrom    String? // "Shift: {shiftId}" or "EOD reset by {name}"
  captureDeclinedAt DateTime? // When last capture attempt was declined
  captureRetryCount Int       @default(0) // Number of capture retry attempts
  lastCaptureError  String? // Last decline reason text

  // Coursing (T013)
  currentCourse Int             @default(1) // Currently active course
  courseMode    OrderCourseMode @default(off)

  // Offline Sync (Store and Forward)
  offlineId         String?   @unique // UUID from terminal for deduplication
  offlineLocalId    String? // Terminal-prefixed ID (e.g., "BAR1-102")
  offlineTimestamp  DateTime? // When order was created offline
  offlineTerminalId String? // Which terminal created this offline

  // Business day tracking (orders at 1 AM belong to previous day's business day)
  businessDayDate DateTime?

  // Online ordering attribution (e.g., "online", "kiosk", "pos")
  source String?

  // Tax exemption (manager.tax_exempt permission required to set)
  isTaxExempt          Boolean  @default(false)
  taxExemptReason      String? // Why order is tax-exempt (e.g., "Government purchase", "Resale")
  taxExemptId          String? // Customer's tax-exempt certificate / tax ID number
  taxExemptApprovedBy  String? // Employee ID who approved the exemption
  taxExemptSavedAmount Decimal? @db.Decimal(10, 2) // Pre-exempt tax amount preserved for audit

  // Order claiming — soft lock to prevent concurrent editing
  claimedByEmployeeId String?
  claimedByEmployee   Employee? @relation("ClaimedOrders", fields: [claimedByEmployeeId], references: [id])
  claimedByTerminalId String? // Terminal ID that currently has the order open
  claimedAt           DateTime? // When the claim was acquired; auto-expires after 60s

  // Order creation idempotency — client-generated key to prevent double-tap duplicates
  // Partial unique index (migration 024) scoped to locationId, non-null keys, non-deleted
  idempotencyKey String?

  // Training mode — training orders skip real payments/printing/inventory
  isTraining Boolean @default(false)

  // HA cellular sync — mutation origin tracking
  lastMutatedBy    String? // 'cloud' | 'local' | null
  originTerminalId String?

  metadata Json? // Settlement order linkage: { cakeOrderId, appliedTo }. Extensible.

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  // Relations
  items               OrderItem[]
  payments            Payment[]
  discounts           OrderDiscount[]
  voidLogs            VoidLog[]
  cards               OrderCard[]
  syncAuditEntries    SyncAuditEntry[]
  remoteVoidApprovals RemoteVoidApproval[]
  orderOwnerships     OrderOwnership[]
  tempSeats           Seat[]               @relation("tempSeats")
  refundLogs          RefundLog[]
  itemDiscounts       OrderItemDiscount[]

  // C-SCHEMA-1: Reverse relations
  couponRedemptions        CouponRedemption[]
  reservations             Reservation[]             @relation("ReservationOrder")
  giftCards                GiftCard[]                @relation("GiftCardOrder")
  giftCardTransactions     GiftCardTransaction[]     @relation("GiftCardTransactionOrder")
  houseAccountTransactions HouseAccountTransaction[] @relation("HouseAcctTxnOrder")
  timedSessions            TimedSession[]
  spiritUpsellEvents       SpiritUpsellEvent[]
  digitalReceipt           DigitalReceipt?
  walkoutRetries           WalkoutRetry[]
  // DB-level constraint (raw SQL in vercel-build.js):
  // UNIQUE INDEX "Order_locationId_orderNumber_unique" ON "Order" ("locationId", "orderNumber")
  // WHERE "parentOrderId" IS NULL
  // Only enforces uniqueness on root orders — split orders share parent's orderNumber.

  // @@index([locationId]) — removed: redundant with compound indexes below

  // C-SCHEMA-1: Reverse relations (batch 2)
  menuItemsInUse     MenuItem[]             @relation("MenuItemCurrentOrder")
  floorPlanElements  FloorPlanElement[]     @relation("FloorPlanCurrentOrder")
  tipLedgerEntries   TipLedgerEntry[]       @relation("TipLedgerOrder")
  tipTransactions    TipTransaction[]       @relation("TipTransactionOrder")
  tickets            Ticket[]               @relation("TicketOrder")
  invTransactions    InventoryTransaction[] @relation("InvTxnOrder")
  printJobs          PrintJob[]             @relation("PrintJobOrder")
  chargebackCases    ChargebackCase[]       @relation("ChargebackOrder")
  errorLogs          ErrorLog[]             @relation("ErrorLogOrder")
  bergDispenseEvents BergDispenseEvent[]

  // Loyalty System (Migration 098)
  loyaltyTransactions LoyaltyTransaction[]

  // Notification Platform (Migration 107)
  pagerNumber       String? // Cache-only. Source of truth = NotificationTargetAssignment
  fulfillmentMode   String? // dine_in, takeout, delivery, curbside, etc.
  readyCycleCounter Int     @default(0) // Increments on send-to-kitchen after recall/remake only

  // Unified Split Checks — ItemShare reverse relations (Migration 118)
  itemSharesAsSource ItemShare[] @relation("ItemShareSourceOrder")
  itemSharesAsTarget ItemShare[] @relation("ItemShareTarget")

  // Entertainment Sessions (Phase 1 — timed rental state machine)
  entertainmentSessions EntertainmentSession[]

  @@index([employeeId])
  @@index([tableId])
  @@index([customerId])
  // @@index([status]) — removed: redundant with @@index([locationId, status]) (all queries include locationId)
  @@index([openedAt])
  // @@index([orderNumber, locationId]) — removed: redundant with @@unique([locationId, orderNumber]) below
  @@index([orderType])
  @@index([orderTypeId])
  @@index([parentOrderId])
  @@index([offlineId])
  @@index([locationId, status])
  @@index([locationId, status, createdAt])
  @@index([locationId, createdAt])
  @@index([tableId, status, deletedAt])
  // DB-level constraint (raw SQL migration 20260223204400_walkin_table_unique_lock):
  // UNIQUE INDEX "Order_tableId_active_unique" ON "Order" ("tableId")
  // WHERE tableId IS NOT NULL AND status IN ('draft','open','in_progress','sent','split') AND deletedAt IS NULL
  // Prevents two live orders on the same walk-in table.
  @@index([locationId, status, openedAt])
  @@index([locationId, tabStatus])
  @@index([locationId, status, closedAt])
  @@index([locationId, orderType, status])
  @@index([locationId, paidAt])
  @@index([locationId, createdAt, status])
  @@index([locationId, businessDayDate])
  @@index([locationId, status, businessDayDate])
  @@index([claimedByEmployeeId, claimedAt])
  @@index([id, version])
  @@index([splitFamilyRootId])
  @@index([splitResolution])
  @@index([locationId, updatedAt])
  @@index([locationId, status, deletedAt])
}

/// ACTIVE: Primary order item table — all reads and writes go here.
/// Mutations MUST also emit events via emitOrderEvent() for the OrderItemSnapshot projection.
/// OrderItem is the source of truth; OrderItemSnapshot is a materialized read-optimized view.
model OrderItem {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  // Item details (snapshot at time of order)
  name     String
  price    Decimal @db.Decimal(10, 2)
  quantity Int     @default(1)

  // Pour size (liquor items) — T-006
  pourSize       String? // "shot", "double", "tall", "short" (null = no pour selection)
  pourMultiplier Decimal? @db.Decimal(10, 4) // 1.0, 2.0, 1.5, 0.75 (null = no pour multiplier applied)

  // Item-level pricing truth (Layer 2)
  cardPrice      Decimal? @db.Decimal(10, 2) // Computed card price at time of order (null if no dual pricing)
  isTaxInclusive Boolean  @default(false) // Was this item tax-inclusive at time of sale?
  categoryType   String? // Snapshot of category type at time of order

  // Seat tracking (Skill 24)
  seatNumber Int?

  // Virtual combine - source table for T-S notation (e.g., T2-S3)
  sourceTableId String? // Which table this item was ordered from
  sourceTable   Table?  @relation("SourceTableOrderItems", fields: [sourceTableId], references: [id])

  // Course (Skill 14)
  courseNumber Int?
  courseStatus CourseStatus @default(pending)

  // Hold & Fire (Skill 15)
  isHeld    Boolean   @default(false)
  holdUntil DateTime?
  firedAt   DateTime?

  // Per-item delay (e.g., 5m, 10m — item waits, then fires to kitchen)
  delayMinutes   Int? // Delay preset in minutes (null = no delay)
  delayStartedAt DateTime? // When the delay timer started (set by send route)

  // Kitchen status
  kitchenStatus KitchenStatus @default(pending)
  kitchenSentAt DateTime? // When item was sent to kitchen (for speed-of-service tracking)

  // KDS completion tracking
  isCompleted            Boolean   @default(false)
  completedAt            DateTime?
  completedBy            String? // Who bumped this item (employee name or "system")
  kdsForwardedToScreenId String? // Screen this item was forwarded to (persists Expo visibility)
  kdsFinalCompleted      Boolean   @default(false) // True only after final bump (no more send_to_next targets)

  // Resend tracking
  resendCount  Int       @default(0)
  lastResentAt DateTime?
  resendNote   String? // Note from server when resending (e.g., "Make it well done")

  // Block time tracking (Skill 97)
  blockTimeMinutes   Int? // Duration purchased (30, 60, 90 mins)
  blockTimeStartedAt DateTime? // When block time started
  blockTimeExpiresAt DateTime? // Calculated expiration time

  // Special requests (Skill 48)
  specialNotes String?

  // Status
  status     OrderItemStatus @default(active)
  voidReason String?
  wasMade    Boolean? // Was item made before void/comp? For waste tracking

  // Weight-Based Selling (Scale Integration)
  soldByWeight Boolean  @default(false) // Was this item sold by weight?
  weight       Decimal? @db.Decimal(10, 4) // Captured NET weight at sale (always post-tare)
  weightUnit   String? // Unit snapshot: "lb" | "kg" | "oz" | "g"
  unitPrice    Decimal? @db.Decimal(10, 2) // Price-per-unit snapshot (e.g. 5.99)
  grossWeight  Decimal? @db.Decimal(10, 4) // Gross weight before tare (audit trail)
  tareWeight   Decimal? @db.Decimal(10, 4) // Tare/container weight (audit trail)

  // Totals
  modifierTotal Decimal @default(0) @db.Decimal(10, 2)
  itemTotal     Decimal @default(0) @db.Decimal(10, 2)

  // Commission (Skill 29)
  commissionAmount Decimal? @db.Decimal(10, 2)

  // Idempotency key for duplicate request prevention
  idempotencyKey String?

  // Pricing Option - selected size/variant at time of order
  pricingOptionId    String?
  pricingOption      PricingOption? @relation(fields: [pricingOptionId], references: [id])
  pricingOptionLabel String? // Snapshot of option label (e.g., "Large", "Bowl")

  // Cost snapshot at time of sale (for historically accurate food cost reports)
  costAtSale Decimal? @db.Decimal(10, 2) // Total ingredient cost (base recipe + pricing option links) at time of order

  // Tip-exempt — snapshot from MenuItem at time of order. Excluded from tip suggestion basis.
  tipExempt Boolean @default(false)

  // Pricing rule applied at time of order (audit/reporting) — PricingAdjustment JSON
  pricingRuleApplied Json?

  // Shared Table Ownership (Skill 253) - who added this item
  addedByEmployeeId String?
  addedByEmployee   Employee? @relation("OrderItemAddedBy", fields: [addedByEmployeeId], references: [id])

  // HA cellular sync — mutation origin tracking
  lastMutatedBy String? // 'cloud' | 'local' | null

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  modifiers               OrderItemModifier[]
  ingredientModifications OrderItemIngredient[]

  // Pizza Builder - detailed pizza configuration
  pizzaData OrderItemPizza?

  // Item-level discounts (P2-D01)
  itemDiscounts OrderItemDiscount[]

  // C-SCHEMA-1: Reverse relations (batch 2)
  menuItemCurrentUse  MenuItem[]           @relation("MenuItemCurrentOrderItem")
  voidLogs            VoidLog[]            @relation("VoidLogItem")
  remoteVoidApprovals RemoteVoidApproval[] @relation("RemoteVoidItem")
  seatCurrentItems    Seat[]               @relation("SeatCurrentItem")

  // Unified Split Checks — ItemShare reverse relation (Migration 118)
  itemShares ItemShare[] @relation("ItemShareSource")

  // Combo Pick N of M — customer-pick snapshots (Migration 129)
  comboSelections OrderItemComboSelection[]

  // Entertainment Session (Phase 1 — timed rental state machine)
  entertainmentSession EntertainmentSession?

  @@index([locationId])
  @@index([orderId])
  @@index([menuItemId])
  @@index([kitchenStatus])
  @@index([orderId, kitchenStatus])
  @@index([orderId, status])
  @@index([orderId, status, deletedAt])
  @@index([locationId, status, kitchenStatus])
  @@index([menuItemId, createdAt]) // PMIX report: product mix by item over time range
  @@index([pricingOptionId])
  @@index([menuItemId, pricingOptionId]) // PMIX/Sales: group by item + size variant
  @@index([locationId, status, updatedAt])
  @@index([kdsForwardedToScreenId, kdsFinalCompleted]) // KDS Overhaul: Expo query index
  @@index([locationId, orderId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String? // Optional: null for combo component selections
  modifier    Modifier? @relation(fields: [modifierId], references: [id])

  // Snapshot at time of sale
  name             String
  price            Decimal @db.Decimal(10, 2) // Actual price charged (may differ from item price if discounted)
  preModifier      String? // "no", "lite", "extra", "side"
  depth            Int     @default(0) // Modifier hierarchy depth: 0=top, 1=child, 2=grandchild
  stackDisplayMode String  @default("individual") // Snapshot from ModifierGroup: "individual" or "combined"

  quantity Int @default(1)

  // Commission (Skill 29)
  commissionAmount Decimal? @db.Decimal(10, 2)

  // Linked Item Snapshot - for reporting which menu item was actually sold
  // Even if ordered as a modifier, this tracks the underlying item for sales reporting
  linkedMenuItemId    String? // Snapshot of linked menu item at time of sale
  linkedMenuItemName  String? // Name snapshot for reporting
  linkedMenuItemPrice Decimal? @db.Decimal(10, 2) // Original item price (before any discount/override)

  // Liquor Builder - Spirit snapshot for reporting
  spiritTier            String? // 'well', 'call', 'premium', 'top_shelf'
  linkedBottleProductId String? // Snapshot of bottle used for inventory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  // HA cellular sync — mutation origin tracking
  lastMutatedBy String? // 'cloud' | 'local' | null

  // Open Entry — freeform custom modifier created at POS
  isCustomEntry    Boolean  @default(false)
  customEntryName  String?
  customEntryPrice Decimal? @db.Decimal(10, 2)

  // None Selection — explicit "None" chosen on a required modifier group
  isNoneSelection   Boolean @default(false)
  noneShowOnReceipt Boolean @default(false)

  // Swap — substitution snapshot at time of order
  swapTargetName     String?
  swapTargetItemId   String?
  swapPricingMode    String? // 'target_price' | 'fixed_price' | 'no_charge'
  swapEffectivePrice Decimal? @db.Decimal(10, 2) // Resolved price at time of order

  @@index([locationId])
  @@index([orderItemId])
  @@index([spiritTier])
  @@index([linkedMenuItemId])
  @@index([locationId, updatedAt])
}

// ============================================
// PAYMENTS (Skill 30)
// ============================================

model Payment {
  id         String    @id @default(cuid())
  locationId String
  location   Location  @relation(fields: [locationId], references: [id])
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)
  employeeId String? // Who processed the payment
  employee   Employee? @relation("PaymentEmployee", fields: [employeeId], references: [id])

  // Cash drawer attribution (Phase: Role-Based Cash Handling)
  drawerId   String? // Which physical drawer received cash (null for card/purse)
  drawer     Drawer?   @relation("PaymentDrawer", fields: [drawerId], references: [id])
  shiftId    String? // Which shift was active (for reconciliation)
  shift      Shift?    @relation("PaymentShift", fields: [shiftId], references: [id])
  terminalId String? // Which terminal processed this payment
  terminal   Terminal? @relation("PaymentTerminal", fields: [terminalId], references: [id])

  // Payment details
  amount      Decimal @db.Decimal(10, 2)
  tipAmount   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  // Method
  paymentMethod PaymentMethod

  // Cash details
  amountTendered     Decimal? @db.Decimal(10, 2) // Amount given by customer
  changeGiven        Decimal? @db.Decimal(10, 2) // Change returned
  roundingAdjustment Decimal? @db.Decimal(10, 2) // Amount rounded (+ or -)

  // Card details (if card)
  cardBrand     String?
  cardLast4     String?
  authCode      String?
  transactionId String?

  // Datacap Direct integration
  paymentReaderId   String? // Which reader processed this payment
  paymentReader     PaymentReader? @relation("PaymentReaderPayments", fields: [paymentReaderId], references: [id])
  datacapRefNumber  String? // Datacap reference for voids/refunds
  datacapRecordNo   String? // RecordNo token — needed for voids, adjustments, captures
  datacapSequenceNo String? // SequenceNo for audit trail
  entryMethod       String? // "Chip" | "Tap" | "Swipe" | "Manual"

  // Datacap processor data for ByRecordNo ops + chargeback defense
  acqRefData     String? // Acquirer reference (for voids/refunds)
  processData    String? // Processor routing data
  aid            String? // EMV Application ID
  cvmResult      String? // Cardholder Verification Method result
  avsResult      String? // AVS check result
  level2Status   String? // B2B interchange qualification
  tokenFrequency String? // 'OneTime' | 'Recurring'

  // Partial Approvals & Signature (Chargeback Defense)
  amountRequested  Decimal? @db.Decimal(10, 2) // Original amount requested
  amountAuthorized Decimal? @db.Decimal(10, 2) // Actual amount approved (may be less for partial approvals)
  signatureData    String? // Base64 signature from reader (chargeback defense)

  // Status
  status PaymentStatus @default(completed)

  // Refund tracking
  refundedAmount Decimal   @default(0) @db.Decimal(10, 2)
  refundedAt     DateTime?
  refundReason   String?

  // Void tracking (separate from refunds - voids mark payment as invalid)
  voidedAt   DateTime?
  voidedBy   String? // Employee ID who voided
  voidReason String?

  settledAt DateTime? // When payment was settled/batched by processor

  // Offline Payment Tracking (Store and Forward)
  offlineIntentId   String?   @unique // UUID from PaymentIntentManager for deduplication
  idempotencyKey    String?   @unique // Terminal+Order+Timestamp fingerprint for deduplication
  isOfflineCapture  Boolean   @default(false) // Was this captured while offline?
  offlineCapturedAt DateTime? // When it was queued for offline capture
  offlineTerminalId String? // Which terminal processed this offline

  // SAF (Store-and-Forward) status tracking
  // Values: APPROVED_ONLINE, APPROVED_SAF_PENDING_UPLOAD, UPLOAD_SUCCESS, UPLOAD_FAILED, NEEDS_ATTENTION
  safStatus     String? // null for cash/non-card; set for all card payments
  safUploadedAt DateTime? // When SAF batch was uploaded to processor
  safError      String? // Last SAF upload error message (UPLOAD_FAILED/NEEDS_ATTENTION)

  // Dual Pricing / Cash Discount (Visa Compliance)
  cashDiscountAmount  Decimal? @db.Decimal(10, 2) // Amount of cash discount applied (null if no dual pricing)
  priceBeforeDiscount Decimal? @db.Decimal(10, 2) // Original card price before cash discount
  pricingMode         String? // "cash" or "card" — which price was used

  // Pricing Tier Detection (Payment & Pricing Redesign)
  detectedCardType       String? // 'credit' | 'debit' | null — from Datacap CardLookup
  appliedPricingTier     String  @default("cash") // 'cash' | 'debit' | 'credit' — which tier was applied
  walletType             String? // 'apple_pay' | 'google_pay' | 'samsung_pay' | null
  pricingProgramSnapshot Json? // Snapshot of pricing config at transaction time

  // Reconciliation (for EOD reports)
  needsReconciliation Boolean   @default(false) // Flag for accountant review
  reconciledAt        DateTime? // When verified against bank statement
  reconciledBy        String? // Employee who verified

  // Sync audit tracking
  syncAttempts        Int     @default(0) // How many times sync was attempted
  wasDuplicateBlocked Boolean @default(false) // Was a duplicate blocked by idempotency?

  // HA cellular sync — mutation origin tracking
  lastMutatedBy String? // 'cloud' | 'local' | null

  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  // Hotel PMS / Bill to Room fields
  roomNumber       String? // Hotel room number charged (e.g. "101")
  guestName        String? // Guest name from PMS (e.g. "John Smith")
  pmsReservationId String? // Oracle OPERA reservation ID
  pmsTransactionId String? // Oracle OPERA folio transaction number

  // Refund logs (P2-P02)
  refundLogs RefundLog[]

  // @@index([locationId]) — removed: redundant with compound indexes below

  // C-SCHEMA-1: Added reverse relations
  tipDebts        TipDebt[]        @relation("TipDebtSourcePayment")
  digitalReceipts DigitalReceipt[]

  // C-SCHEMA-1: Reverse relations (batch 2)
  tipTransactions  TipTransaction[] @relation("TipTransactionPayment")
  tickets          Ticket[]         @relation("TicketPayment")
  chargebackCases  ChargebackCase[] @relation("ChargebackPayment")
  errorLogs        ErrorLog[]       @relation("ErrorLogPayment")
  syncAuditEntries SyncAuditEntry[] @relation("SyncAuditPayment")

  @@index([orderId])
  @@index([processedAt])
  @@index([employeeId])
  @@index([isOfflineCapture])
  @@index([safStatus])
  @@index([needsReconciliation])
  @@index([locationId, createdAt])
  @@index([locationId, paymentMethod, createdAt])
  @@index([locationId, status, createdAt])
  @@index([shiftId])
  @@index([drawerId])
  @@index([idempotencyKey])
  @@index([offlineIntentId])
  @@index([orderId, status])
  @@index([employeeId, processedAt])
  @@index([locationId, updatedAt])
  @@index([locationId, employeeId, createdAt])
}

// Sync Audit Entry - Tracks all sync events for idempotency audit log
model SyncAuditEntry {
  id         String   @id @default(cuid())
