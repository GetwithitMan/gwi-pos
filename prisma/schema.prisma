  memo                String?
  status              TipDebtStatus @default(open)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  recoveredAt         DateTime?
  writtenOffAt        DateTime?
  writtenOffBy        String?
  deletedAt           DateTime?
  syncedAt            DateTime?

  @@index([locationId])
  @@index([employeeId])
  @@index([status])
}

// ============================================
// ORDER OWNERSHIP (Skill 253 - Shared Tables)
