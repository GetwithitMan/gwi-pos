  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())

  @@index([locationId, status])
  @@index([driverId])
  @@index([orderId])
  @@index([locationId, createdAt(sort: Desc)])
  @@index([zoneId])
  @@index([runId])
}

// ============================================
// EXTERNAL WEBHOOK EVENTS (idempotency + replay protection)
// ============================================

model ExternalWebhookEvent {
  id                    String                  @id @default(cuid())
  provider              String // 'datacap_virtual_gift'
  externalTransactionId String // e.g. Datacap transactionId
  eventType             String // e.g. 'payment.completed', 'payment.failed'
  signatureValid        Boolean
  payload               Json // Raw webhook body (CVV stripped, contains PII — 90-day retention)
  processingStatus      WebhookProcessingStatus @default(received)
  ignoredReason         String? // Why event was ignored (unknown type, etc.)
  relatedGiftCardId     String? // GiftCard created/affected by this event
  providerPageId        String? // e.g. Datacap giftCardPageId
  providerMerchantId    String? // e.g. Datacap merchantId
  attemptCount          Int                     @default(1)
  receivedAt            DateTime                @default(now())
  processedAt           DateTime?
  errorMessage          String?

  // Unique per (provider, transaction, event type) — Datacap sends
  // multiple event types for the same transaction lifecycle
  @@unique([provider, externalTransactionId, eventType])
  @@index([provider, processingStatus])
}

// ============================================
// UNIFIED SPLIT CHECKS (Phase 1, Migration 118)
// ============================================

/// Item-level share splits: one line item's cost divided across multiple checks.
/// Source item stays canonical on its owning check; shares are accounting entries only.
/// Receipt display: "1/3 Ribeye — $18.33"
model ItemShare {
  id                  String    @id @default(cuid())
  locationId          String
  sourceItemId        String // The canonical OrderItem being shared
  sourceOrderId       String // Order that owns the canonical item
  targetOrderId       String // Check that owes this share
  shareIndex          Int // 1-based (1 of 3, 2 of 3, etc.)
  totalShares         Int // N in "split N ways"
  allocatedAmount     Decimal   @db.Decimal(10, 2) // This share's dollar amount (after penny distribution)
  allocatedTax        Decimal   @default(0) @db.Decimal(10, 2)
  allocatedDiscount   Decimal   @default(0) @db.Decimal(10, 2)
  resolvedAt          DateTime? // When this share was paid/superseded
  resolvedByPaymentId String? // Payment that resolved this share
  splitResolution     String? // null | 'paid' | 'superseded' | 'merged_back'
  createdAt           DateTime  @default(now())
  deletedAt           DateTime?

  sourceItem  OrderItem @relation("ItemShareSource", fields: [sourceItemId], references: [id])
  sourceOrder Order     @relation("ItemShareSourceOrder", fields: [sourceOrderId], references: [id])
  targetOrder Order     @relation("ItemShareTarget", fields: [targetOrderId], references: [id])
  location    Location  @relation(fields: [locationId], references: [id])

  @@index([sourceItemId])
  @@index([targetOrderId])
  @@index([sourceOrderId])
  @@index([locationId])
}

// ── Integration Retry Queue ────────────────────────────────────────────────
model IntegrationRetryEntry {
  id          String    @id @default(cuid())
  locationId  String
  integration String
  action      String
  payload     Json
  retryCount  Int       @default(0)
  maxRetries  Int       @default(5)
  lastError   String?
  status      String    @default("pending")
  nextRetryAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, status, nextRetryAt])
  @@index([integration, status])
}

// ============================================
// PERIPHERAL SNAPSHOT (Upstream Sync to MC)
// ============================================

/// Periodic snapshot of peripheral device status for upstream sync to Neon/MC.
/// Written every 60 seconds by the peripheral snapshot writer on the NUC.
/// Enables MC fleet dashboard to show live device health across all venues.
model PeripheralSnapshot {
  id            String    @id @default(cuid())
  locationId    String
  location      Location  @relation(fields: [locationId], references: [id])
  deviceType    String // 'terminal' | 'printer' | 'reader' | 'scale' | 'kds'
  deviceId      String
  deviceName    String
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime?
  lastError     String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  lastMutatedBy String? // 'cloud' | 'local' | null
  syncedAt      DateTime?

  @@unique([locationId, deviceType, deviceId])
  @@index([locationId])
  @@index([locationId, updatedAt])
}

// NOTE: _local_schema_state and _local_install_state are NUC-only tables
// created by the installer/bootstrap with raw SQL. They use SERIAL id columns
// which conflict with Prisma's autoincrement on the Neon master DB.
// They are NOT in the Prisma schema — prisma db push will try to drop them
// on NUCs, but the pre-start script recreates them. On Vercel/Neon master,
// they simply don't exist (and shouldn't).
