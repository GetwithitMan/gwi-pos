// ============================================
// BARCODE SCANNING
// Maps multiple barcodes to menu/inventory items with pack-size pricing
// ============================================

model ItemBarcode {
  id       String   @id @default(cuid())
  barcode  String // UPC/EAN/custom code
  label    String? // "Single", "6-Pack", "Case", "750ml"
  packSize Int      @default(1) // Units per scan (1, 6, 12, 24)
  price    Decimal? @db.Decimal(10, 2) // Override price for this pack size (null = use base × packSize)

  // Link to one of: MenuItem or InventoryItem (or both)
  menuItemId      String?
  menuItem        MenuItem?      @relation(fields: [menuItemId], references: [id])
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  syncedAt  DateTime?

  @@unique([locationId, barcode]) // One barcode per location
  @@index([barcode]) // Fast lookup
  @@index([menuItemId])
  @@index([inventoryItemId])
  @@index([locationId])
}

// ============================================
// CLOUD-PRIMARY ARCHITECTURE
// Fulfillment queue, bridge checkpoints, and outage replay
// ============================================

model FulfillmentEvent {
  id          String    @id @default(cuid())
  locationId  String
  orderId     String
  stationId   String?
  type        String // print_kitchen, print_bar, kds_update, drawer_kick
  status      String    @default("pending") // pending, claimed, completed, failed, dead_letter
  payload     Json?
  claimedBy   String? // NUC node ID that claimed this event
  claimedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  location    Location  @relation(fields: [locationId], references: [id])

  @@index([locationId, status])
  @@index([claimedBy, status])
}

model BridgeCheckpoint {
  id                String    @id @default(cuid())
  locationId        String
  nodeId            String // NUC identifier
  role              String // primary, backup
  leaseExpiresAt    DateTime
  lastHeartbeat     DateTime
  lastFulfillmentAt DateTime?
  fulfillmentLag    Int? // ms since last processed event
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  location          Location  @relation(fields: [locationId], references: [id])

  @@unique([locationId, nodeId])
}

// outageId groups entries by connectivity window. Increment when connectivity
// flips from "cloud reachable" to "unreachable" and back. This enables tooling
// to reason about "one outage window" and batch-resolve conflicts per outage.
model OutageQueueEntry {
  id             String            @id @default(cuid())
  locationId     String
  tableName      String
  recordId       String
  operation      OutageOperation // INSERT, UPDATE, DELETE
  payload        Json
  localSeq       BigInt // monotonic local sequence
  idempotencyKey String            @unique // {locationId}:{tableName}:{recordId}:{localSeq}
  status         OutageQueueStatus @default(PENDING)
  outageId       String? // Groups entries by connectivity window (incremented on outage start)
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  replayedAt     DateTime?
  location       Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, status])
  @@index([outageId])
}

