  redeemedBy String? // Employee who applied
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Sync fields (for cloud sync and soft deletes)
  deletedAt DateTime?
  syncedAt  DateTime?

  @@index([locationId])
  @@index([couponId])
  @@index([orderId])
  @@index([customerId])
}

