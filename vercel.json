{
  "buildCommand": "node scripts/vercel-build.js",
  "framework": "nextjs",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/7shifts-sync", "schedule": "0 7 * * *" },
    { "path": "/api/cron/marginedge-sync", "schedule": "0 8 * * *" },
    { "path": "/api/cron/process-deductions", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/berg-reprocess", "schedule": "* * * * *" },
    { "path": "/api/cron/entertainment-expiry", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/eod-batch-close", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/expire-payment-links", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/process-memberships", "schedule": "0 * * * *" },
    { "path": "/api/cron/reservation-hold-expiry", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/reservation-no-shows", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/reservation-reminders", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/reservation-thank-you", "schedule": "*/30 * * * *" }
  ]
}
