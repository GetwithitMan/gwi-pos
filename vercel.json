{
  "buildCommand": "node scripts/vercel-build.js",
  "framework": "nextjs",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/artifacts/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/artifacts/(.*).minisig",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/7shifts-sync", "schedule": "0 7 * * *" },
    { "path": "/api/cron/marginedge-sync", "schedule": "0 8 * * *" },
    { "path": "/api/cron/process-deductions", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/berg-reprocess", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/entertainment-expiry", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/eod-batch-close", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/expire-payment-links", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/process-memberships", "schedule": "0 * * * *" },
    { "path": "/api/cron/reservation-hold-expiry", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/reservation-no-shows", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/reservation-reminders", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/reservation-thank-you", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/process-scheduled-orders", "schedule": "*/2 * * * *" },
    { "path": "/api/cron/accounting-export", "schedule": "0 * * * *" },
    { "path": "/api/cron/delivery-maintenance", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/expire-shared-reports", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/invoice-overdue", "schedule": "0 * * * *" },
    { "path": "/api/cron/pms-reconciliation", "schedule": "0 * * * *" },
    { "path": "/api/cron/datacap-reconciliation", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/walkout-retry", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/online-order-timeout", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/entertainment-waitlist-expiry", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/notification-reaper", "schedule": "0 * * * *" },
    { "path": "/api/cron/notification-archive", "schedule": "0 3 * * *" }
  ]
}
