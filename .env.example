# GWI POS Environment Variables
# Copy this file to .env.local and fill in your values.
# A new developer should be able to set up from this file alone.
#
# Required vars are uncommented. Optional vars are commented out.
# NEVER commit real secrets to this file.

# ============================================
# DATABASE (PostgreSQL — required)
# ============================================
# Pooler connection (for app queries, serverless-friendly on Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/gwi_pos?sslmode=prefer"
# Direct connection (for schema migrations only — bypasses pgBouncer)
DIRECT_URL="postgresql://user:password@localhost:5432/gwi_pos?sslmode=prefer"

# Neon cloud database (used by sync workers for cross-origin data access)
# Only needed on NUC — leave empty for Vercel/dev
# NEON_DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/gwi_pos?sslmode=require"
# NEON_DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/gwi_pos?sslmode=require"

# Connection pool size for Neon client (NUC only, default: 3)
# DB_POOL_SIZE="3"

# Access log database URL (defaults to DATABASE_URL if not set)
# ACCESS_DATABASE_URL=""

# Local database URL (used by copy/migration scripts)
# LOCAL_DB_URL="postgresql://user:password@localhost:5432/gwi_pos"

# Max venue client connections cached in memory (default: unlimited)
# MAX_VENUE_CLIENTS="50"
# Venue client idle TTL in ms before eviction
# VENUE_CLIENT_TTL_MS="300000"

# ============================================
# AUTH / SECRETS (required in production)
# ============================================
# Session signing secret — MUST be set in production (random 64+ char hex)
# Used for HMAC-SHA256 signed httpOnly session cookies
SESSION_SECRET="change-me-generate-with-openssl-rand-hex-32"
# Alias (either works): NEXTAUTH_SECRET=""

# Internal API secret — protects socket broadcast, sync triggers, cloud-identity endpoints
INTERNAL_API_SECRET="change-this-in-production"

# Portal HMAC secret — signs customer portal tokens, OTPs, order view links
# MUST be set in production
# PORTAL_HMAC_SECRET="change-me-generate-with-openssl-rand-hex-32"

# JWT secret for cloud token verification
# JWT_SECRET=""

# ============================================
# NUC IDENTITY (set by installer on production NUCs)
# ============================================
# The location this NUC serves (UUID)
# POS_LOCATION_ID=""
# Venue slug for multi-tenant routing
# POS_VENUE_SLUG=""
# Alias for location ID
# LOCATION_ID=""
# NUC node identifier for HA clustering
# NUC_NODE_ID="primary"
# NUC role in HA cluster (primary/standby)
# NUC_ROLE="primary"
# Station role (e.g., "bar", "host")
# STATION_ROLE=""
# Timezone for date calculations (IANA, e.g., "America/New_York")
# TIMEZONE="America/New_York"
# TZ="America/New_York"

# ============================================
# REAL-TIME EVENTS (Socket.io)
# ============================================
# "socket" enables Socket.io via custom server.ts (local dev / NUC)
# Omit or leave empty for Vercel (serverless, no Socket.io)
NEXT_PUBLIC_EVENT_PROVIDER="socket"

# Socket connection URLs (defaults to localhost:3000 if not set)
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Debug socket events (verbose logging)
# DEBUG_SOCKETS="true"

# ─── WebSocket Process Separation ───
# Set to "true" to run Socket.io in a standalone process (ws-server.ts)
# WS_STANDALONE="false"
# WS_SERVER_URL="http://localhost:3001"
# NEXT_PUBLIC_WS_URL="http://localhost:3001"
# SOCKET_PATH="/api/socket"
# WS_PORT="3001"

# ============================================
# SYNC (NUC <-> Neon Cloud)
# ============================================
# Enable/disable sync workers
# SYNC_ENABLED="true"

# Sync interval in ms (default: 5000 = 5 seconds)
# SYNC_UPSTREAM_INTERVAL_MS="5000"
# SYNC_DOWNSTREAM_INTERVAL_MS="5000"

# Quarantine mode: log conflicts instead of overwriting
# SYNC_QUARANTINE_MODE="false"

# Max entries in outage queue before dropping oldest
# MAX_OUTAGE_QUEUE_SIZE="10000"

# ============================================
# CLOUD / MISSION CONTROL
# ============================================
# Shared secret between POS and Mission Control
# Used for: JWT signing (cloud auth), provision API auth
# Must match PROVISION_API_KEY in Mission Control
# PROVISION_API_KEY=""

# Mission Control dashboard URL (for cloud admin redirects)
# MISSION_CONTROL_URL="https://app.thepasspos.com"
# MC_BASE_URL="https://app.thepasspos.com"
# MC_API_KEY=""

# Cloud WebSocket relay URL (wss://relay.thepasspos.com)
# CLOUD_RELAY_URL=""

# Cloud backoffice integration (NUC -> Cloud event pipeline)
# Set automatically by installer.run on production NUCs
# BACKOFFICE_API_URL="http://localhost:8080"
# SERVER_API_KEY="dev-secret"
# SERVER_NODE_ID="dev-nuc-1"

# Internal base URL for self-referencing API calls
# INTERNAL_BASE_URL="http://localhost:3000"

# ============================================
# CELLULAR / HA FAILOVER
# ============================================
# Cellular device claim key (shared secret for device pairing)
# CELLULAR_CLAIM_KEY=""
# Cellular token signing secret
# CELLULAR_TOKEN_SECRET=""
# HA shared secret for primary/standby communication
# HA_SHARED_SECRET=""
# Virtual IP for HA failover
# VIRTUAL_IP=""

# ============================================
# BRIDGE / FLEET
# ============================================
# Bridge bootstrap secret for initial NUC registration
# BRIDGE_BOOTSTRAP_SECRET=""
# Bridge master key for ongoing bridge communication
# BRIDGE_MASTER_KEY=""
# Bridge secrets (JSON array of valid secrets)
# GWI_BRIDGE_SECRETS='["secret1","secret2"]'
# Fleet notification secret
# FLEET_NOTIFY_SECRET=""

# ============================================
# TENANT SECURITY
# ============================================
# Enable JWT-based tenant isolation
# TENANT_JWT_ENABLED="false"
# Signing key for tenant JWTs
# TENANT_SIGNING_KEY=""
# Allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS="http://localhost:3000"

# ============================================
# DATACAP (Payment Processing)
# ============================================
# PayAPI credentials for online/text-to-pay payments
# DATACAP_PAYAPI_KEY=""
# DATACAP_PAYAPI_MID=""
# DATACAP_PAYAPI_ENV="uat"
# NEXT_PUBLIC_DATACAP_PAYAPI_TOKEN_KEY=""

# Token-based payments (client-side)
# NEXT_PUBLIC_DATACAP_TOKEN_KEY=""
# NEXT_PUBLIC_DATACAP_TOKEN_ENV="uat"
# NEXT_PUBLIC_DATACAP_ENV="uat"

# Reporting API for settlement reconciliation
# DATACAP_REPORTING_API_KEY=""

# ============================================
# SMS & EMAIL ALERTS
# ============================================
# Twilio (for SMS remote void approval, delivery tracking, text-to-pay)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER="+15551234567"
# TWILIO_TO_NUMBER="+15559876543"

# Email alerts (via Resend)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@gwipos.com"
# EMAIL_TO="alerts@example.com"

# Slack alerts
# SLACK_WEBHOOK_URL=""

# ============================================
# INTEGRATIONS
# ============================================
# Berg dispensing system
# BERG_ENABLED="false"
# BERG_LOCATION_ID=""
# BERG_SIM_SECRET=""
# BERG_TEST_DEVICE_ID=""
# BERG_TEST_DEVICE_IDS=""
# BERG_IDEMPOTENCY_WINDOW_MS="60000"

# Pour control (smart liquor dispensers)
# POUR_CONTROL_WEBHOOK_SECRET=""

# Google Cloud (push notifications)
# GOOGLE_CLOUD_PROJECT_NUMBER=""
# GOOGLE_SERVICE_ACCOUNT_KEY=""

# Marketing unsubscribe link signing
# MARKETING_UNSUBSCRIBE_SECRET=""

# ============================================
# APP / SERVER
# ============================================
# Server port (default: 3000, dev uses 3006 via package.json)
# PORT="3000"
# Hostname binding
# HOSTNAME="localhost"

# App base URL (defaults to http://localhost:3000)
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# APP_URL="http://localhost:3000"
# GWI_POS_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_VERSION="0.0.0"

# App directory (used by scripts)
# APP_DIR="/opt/gwi-pos"

# Cron job secret (Vercel cron authentication)
# CRON_SECRET=""

# ============================================
# FEATURE FLAGS
# ============================================
# Allow purge operations (dangerous — dev/staging only)
# ALLOW_PURGE="false"

# Staging mode (relaxes some production safety checks)
# STAGING="false"

# Hardware command retention in ms (default: 1 hour)
# HW_COMMAND_RETAIN_MS="3600000"

# GWI access secret (internal tooling)
# GWI_ACCESS_SECRET=""
# INTERNAL_API_KEY=""

# ============================================
# TESTING (never set in production)
# ============================================
# TEST_BASE_URL="http://localhost:3000"
# TEST_EMPLOYEE_ID=""
# TEST_EMPLOYEE_PIN=""
# TEST_LOCATION_ID=""
