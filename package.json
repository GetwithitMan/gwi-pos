{
  "name": "gwi-pos",
  "version": "1.2.67",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3006 --webpack",
    "dev:server": "NODE_OPTIONS='--max-old-space-size=8192' dotenv -e .env.local -- tsx -r ./preload.js server.ts",
    "prebuild": "if [ \"$SKIP_TYPECHECK\" = '1' ]; then echo 'Skipping typecheck (SKIP_TYPECHECK=1)'; else NODE_OPTIONS='--max-old-space-size=16384' tsc --noEmit --incremental; fi",
    "build": "bash scripts/bump-version.sh && rm -rf node_modules/.prisma && prisma generate && node scripts/generate-schema-sql.mjs && cp prisma/schema.sql public/schema.sql && node scripts/generate-version-contract.mjs && cp src/generated/version-contract.json public/version-contract.json && node scripts/generate-artifacts.mjs && bash scripts/build-installer-bundle.sh && next build && node scripts/build-server.mjs",
    "schema:sql": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > prisma/schema.sql",
    "start": "NODE_ENV=production node -r ./preload.js server.js",
    "start:next": "next start",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=16384' tsc --noEmit",
    "lint": "eslint",
    "check:auth": "node scripts/check-auth-patterns.mjs",
    "postinstall": "rm -rf node_modules/.prisma && prisma generate",
    "setup": "prisma generate && prisma db push && npm run db:seed",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:backup": "dotenv -e .env.local -- bash -c 'mkdir -p prisma/backups && pg_dump \"$DATABASE_URL\" --no-owner --no-acl -Fc -f prisma/backups/backup-$(date +%Y%m%d-%H%M%S).dump && echo \"Backup saved to prisma/backups/\"'",
    "db:restore": "dotenv -e .env.local -- bash -c 'LATEST=$(ls -t prisma/backups/*.dump 2>/dev/null | head -1) && [ -n \"$LATEST\" ] && pg_restore --no-owner --no-acl --clean --if-exists -d \"$DATABASE_URL\" \"$LATEST\" && echo \"Restored from $LATEST\" || echo \"No backup files found in prisma/backups/\"'",
    "db:list-backups": "ls -lh prisma/backups/*.dump 2>/dev/null || echo 'No backups found'",
    "db:clean": "dotenv -e .env.local -- tsx scripts/clean-dev-db.ts",
    "db:seed-liquor": "dotenv -e .env.local -- tsx scripts/seed-liquor.ts",
    "db:seed-cocktails": "dotenv -e .env.local -- tsx scripts/seed-cocktails.ts",
    "db:seed-brands": "dotenv -e .env.local -- tsx scripts/seed-brand-upgrades.ts",
    "fix-orphaned-labels": "npx tsx scripts/fix-orphaned-seat-labels.ts",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:ui": "playwright test --ui",
    "test:floor-plan": "playwright test floor-plan.spec.ts",
    "test:headed": "playwright test --headed",
    "ws:dev": "SOCKET_PATH=/ws dotenv -e .env.local -- tsx ws-server.ts",
    "ws:build": "node scripts/build-ws-server.mjs",
    "build:all": "npm run build && npm run ws:build",
    "build:prestaged-bundle": "bash scripts/build-offline-bundle.sh",
    "build:iso": "bash scripts/build-custom-iso.sh",
    "write-usb": "sudo bash scripts/write-usb.sh",
    "load-test": "npx tsx scripts/load-test.ts"
  },
  "dependencies": {
    "@csstools/postcss-oklab-function": "^5.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nextjs": "^10.42.0",
    "@serialport/parser-readline": "^13.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/compression": "^1.8.1",
    "@types/leaflet": "^1.9.21",
    "@types/pdfkit": "^0.17.4",
    "accepts": "^1.3.8",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dexie": "^4.3.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "framer-motion": "^12.29.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-virtuoso": "^4.18.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "twilio": "^5.12.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prisma": "^7.5.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "browserslist": [
    "chrome >= 108",
    "firefox >= 115",
    "safari >= 15.4",
    "edge >= 108"
  ]
}
